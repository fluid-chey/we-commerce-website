{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Blog section  -->
<section class="blog-section {{ section.settings.section_padding_top_mobile | default: 'pt-5xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-5xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .blog-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  <div class="container">
    <div class="header text-center flex flex-col {{ section.settings.title_spacing_mobile | default: 'space-xl' }} {{ section.settings.title_spacing_desktop | default: 'lg:space-2xl' }}">
      <div class="{{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">
        {{ section.settings.heading | default: "Short heading goes here" }}
      </div>
      {% if section.settings.intro_text != blank %}
      <p class="{{ section.settings.intro_font_size | default: 'text-base' }} {{ section.settings.intro_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.intro_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.intro_color | default: '#000000' }};">
        {{ section.settings.intro_text }}
      </p>
      {% endif %}
    </div>

    <div class="blog-grid-section {{ section.settings.content_spacing_mobile | default: 'pt-5xl' }} {{ section.settings.content_spacing_desktop | default: 'lg:pt-5xl' }}">
      <div class="grid grid-cols-1 {{ section.settings.grid_columns_tablet | default: 'lg-tab-grid-cols-2' }} {{ section.settings.grid_columns_desktop | default: 'xl-desktop-grid-cols-3' }} {{ section.settings.grid_gap_mobile | default: 'space-5xl' }} {{ section.settings.grid_gap_desktop | default: 'lg:space-5xl' }} blog-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'blog_post' %}
              <div class="blog-col flex flex-col {{ section.settings.blog_item_spacing_mobile | default: 'space-xl' }} {{ section.settings.blog_item_spacing_desktop | default: 'lg:space-2xl' }}" {{ block.fluid_attributes }}>
                <figure class="blog-image relative overflow-hidden {{ block.settings.image_border_radius | default: '' }}" style="height: {{ block.settings.image_height | default: 'auto' }};">
                  {% comment %} Handle blog_image - can be string URL or object with url/fluid_media_id {% endcomment %}
                  {% assign img_input = block.settings.blog_image %}
                  {% assign img_fluid_media_id = '' %}
                  
                  {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
                  {% if img_input.fluid_media_id %}
                    {% assign img_fluid_media_id = img_input.fluid_media_id %}
                    {% assign img_embed_type = img_input.embed_type %}
                  {% endif %}

                  {% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
                  {% assign use_fluid_image_widget = false %}
                  
                  {% if img_fluid_media_id != '' %}
                    {% assign use_fluid_image_widget = true %}
                  {% endif %}
                  
                  {% if use_fluid_image_widget %}
                    <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
                  {% else %}
                    {% if img_input != '' %}
                      <img src="{{img_input}}" alt="{{ block.settings.blog_title | default: 'Blog post' }}" class="image-cover" loading="lazy" width="" height=""/>
                    {% else %}
                      <img src="{{ 'blog-placeholder.png' | asset_url }}" alt="blog" class="image-cover" width="" height=""/>
                    {% endif %}
                  {% endif %}
                </figure>
                <div class="blog-content flex flex-col {{ section.settings.blog_content_spacing_mobile | default: 'space-md' }} {{ section.settings.blog_content_spacing_desktop | default: 'lg:space-lg' }}">
                  {% if block.settings.show_category and block.settings.blog_category != blank %}
                  <div class="blog-category">
                    <span class="{{ block.settings.category_font_size | default: 'text-sm' }} {{ block.settings.category_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.category_color | default: '#666666' }};">
                      {{ block.settings.blog_category }}
                    </span>
                  </div>
                  {% endif %}
                  <h4 class="{{ block.settings.title_font_size | default: 'text-h4' }} {{ block.settings.title_font_weight | default: 'font-semibold' }}" style="color: {{ block.settings.title_color | default: '#000000' }};">
                    {{ block.settings.blog_title | default: "Blog title heading will go here" }}
                  </h4>
                  <p class="{{ block.settings.content_font_size | default: 'text-base' }} {{ block.settings.content_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.content_font_weight | default: 'font-normal' }}" style="color: {{ block.settings.content_color | default: '#000000' }};">
                    {{ block.settings.blog_excerpt | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare." }}
                  </p>
                  {% if block.settings.show_author and block.settings.author_name != blank %}
                  <div class="blog-author flex align-center {{ section.settings.author_gap | default: 'space-sm' }}">
                    {% assign author_img_input = block.settings.author_image %}
                    {% assign author_img_fluid_media_id = '' %}
                    
                    {% if author_img_input.fluid_media_id %}
                      {% assign author_img_fluid_media_id = author_img_input.fluid_media_id %}
                      {% assign author_img_embed_type = author_img_input.embed_type %}
                    {% endif %}
                    
                    {% assign use_author_fluid_image_widget = false %}
                    
                    {% if author_img_fluid_media_id != '' %}
                      {% assign use_author_fluid_image_widget = true %}
                    {% endif %}
                    
                    {% if use_author_fluid_image_widget %}
                      <fluid-media-widget class="fluid-media-widget-image" media-id="{{ author_img_fluid_media_id }}" responsive="true" embed-type="{{ author_img_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
                    {% else %}
                      {% if author_img_input != '' %}
                        <img src="{{ author_img_input | image_url: width: 40 }}" alt="{{ block.settings.author_name }}" class="rounded-full w-10 h-10 object-cover" loading="lazy" width="" height=""/>
                      {% else %}
                        <img src="{{ 'avatar.png' | asset_url }}" alt="{{ block.settings.author_name }}" class="rounded-full w-10 h-10 object-cover" loading="lazy" width="" height=""/>
                      {% endif %}
                    {% endif %}
                    <div class="flex flex-col {{ section.settings.author_info_spacing | default: 'space-xs' }}">
                      <p class="{{ block.settings.author_font_size | default: 'text-sm' }} {{ block.settings.author_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.author_color | default: '#000000' }};">
                        {{ block.settings.author_name }}
                      </p>
                      {% if block.settings.publish_date != blank %}
                      <p class="text-xs" style="color: {{ block.settings.date_color | default: '#666666' }};">
                        {{ block.settings.publish_date }}
                      </p>
                      {% endif %}
                    </div>
                  </div>
                  {% endif %}
                  {% if block.settings.show_read_more %}
                  <div class="blog-btn {{ block.settings.button_margin_top | default: 'mt-md' }}">
                    <a href="{{ block.settings.blog_url | default: '#' }}" class="btn {{ block.settings.button_style | default: 'btn-link' }}" style="color: {{ block.settings.button_color | default: '#000000' }};">
                      <span>{{ block.settings.button_text | default: "Read more" }}</span>
                      {% if block.settings.show_button_icon %}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="25"
                        viewBox="0 0 24 25"
                        fill="none"
                        class="mt-1"
                      >
                        <path
                          d="M9.70697 17.3491L15.414 11.6421L9.70697 5.93506L8.29297 7.34906L12.586 11.6421L8.29297 15.9351L9.70697 17.3491Z"
                          fill="currentColor"
                        />
                      </svg>
                      {% endif %}
                    </a>
                  </div>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

