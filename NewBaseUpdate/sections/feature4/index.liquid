      "type": "text",
      "id": "point_2_heading",
      "default": "Short heading goes here",
      "label": "Feature Point 2 - Heading"
    },
    {
      "type": "textarea",
      "id": "point_2_description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.",
      "label": "Feature Point 2 - Description"
    },
    {
      "type": "image_picker",
      "id": "point_3_image",
      "label": "Feature Point 3 - Image"
    },
    {
      "type": "text",
      "id": "point_3_image_alt",
      "label": "Feature Point 3 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "text",
      "id": "point_3_heading",
      "default": "Short heading goes here",
      "label": "Feature Point 3 - Heading"
    },
    {
      "type": "textarea",
      "id": "point_3_description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.",
      "label": "Feature Point 3 - Description"
    },
    {
      "type": "image_picker",
