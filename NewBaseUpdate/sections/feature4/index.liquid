          "label": "Heading 1"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        }
      ],
      "default": "h2",
      "label": "Heading Size"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Central Feature Image"
    },
    {
