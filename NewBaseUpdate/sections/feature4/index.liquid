      "id": "heading_color",
      "default": "#1a1a1a",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
      "id": "description_color",
      "default": "#6b7280",
      "label": "Description Color"
    },
    {
      "type": "color_background",
      "id": "point_heading_color",
      "default": "#1a1a1a",
      "label": "Feature Point Heading Color"
    },
    {
      "type": "color_background",
      "id": "point_text_color",
      "default": "#6b7280",
      "label": "Feature Point Text Color"
    },
    {
      "type": "color_background",
      "id": "primary_button_bg",
      "default": "#000000",
      "label": "Primary Button Background"
    },
    {
      "type": "color_background",
      "id": "primary_button_text_color",
      "default": "#ffffff",
      "label": "Primary Button Text Color"
    },
    {
      "type": "color_background",
      "id": "secondary_button_text_color",
      "default": "#000000",
      "label": "Secondary Button Text Color"
    },
    {
      "type": "color_background",
      "id": "secondary_button_border_color",
      "default": "#000000",
      "label": "Secondary Button Border Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
