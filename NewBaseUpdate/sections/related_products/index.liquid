<section class="product-collection-section {{ section.settings.section_padding_top_mobile | default: 'pt-5xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-5xl' }}" data-bg="{{ section.settings.background_image }}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }}; color: {{ section.settings.text_color | default: '#000000' }};">
  <style>
    @media (min-width: 1280px) {
      .product-collection-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  <div class="container">
    <div class="">
      <span class="{{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.tagline_color | default: '#000000' }};">
        {{ section.settings.tagline | default: "Tagline" }}
      </span>
      <div class="{{ section.settings.heading_spacing_mobile | default: 'py-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:py-lg' }} {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_size_desktop | default: 'text-h1' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">
        {{ section.settings.heading | default: "Related Products" }}
      </div>
      <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#000000' }};">
        {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }}
      </p>
    </div>
    
    <div class="product-list-section {{ section.settings.product_list_spacing_mobile | default: 'mt-4xl' }} {{ section.settings.product_list_spacing_desktop | default: 'lg:mt-7xl' }}">
      <ul class="grid grid-cols-1 xl-phone-grid-cols-2 md-tab-grid-cols-3 {{ section.settings.grid_gap_x_mobile | default: 'space-x-4xl' }} {{ section.settings.grid_gap_x_desktop | default: 'lg:space-x-7xl' }} {{ section.settings.grid_gap_y_mobile | default: 'space-y-7xl' }} {{ section.settings.grid_gap_y_desktop | default: 'lg:space-y-9xl' }}">
        {% for recommendation in product.recommendations limit: section.settings.products_to_show %}
          <li>
            <a href="{{ recommendation.url }}" class="product block">
              <div class="image-section product-image-height">
                <img
                  src="{{ recommendation.image_url }}"
                  alt="{{ recommendation.title }}"
                  class="image-cover"
                  loading="lazy"
                  width=""
                  height=""
                />
              </div>
              <div class="desc {{ section.settings.product_content_spacing_mobile | default: 'pt-md' }} {{ section.settings.product_content_spacing_desktop | default: 'lg:pt-lg' }} text-center  ">
                <div class="{{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_title_font_weight | default: 'font-medium' }}" style="color: {{ section.settings.product_title_color | default: '#000000' }};">
                  {{ recommendation.title}}
                </div>
                <p class="{{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.product_variant_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.product_variant_color | default: '#666666' }};">
                  {{ 'product.variant' | t }}
                </p>
                <div class="{{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.product_price_color | default: '#000000' }};">
                  {{ recommendation.price }}
                </div>
              </div>
            </a>
          </li>
        {%  endfor %}
      </ul>
    </div>

    {% if section.settings.show_view_all_button %}
    <div class="btn-section {{ section.settings.button_spacing_mobile | default: 'mt-7xl' }} {{ section.settings.button_spacing_desktop | default: 'lg:mt-10xl' }} flex justify-center">
      <a href="{{ section.settings.view_all_url | default: '#' }}" class="btn {{ section.settings.button_style | default: 'btn-border-primary' }} {{ section.settings.button_border_radius | default: '' }}">
        {{ section.settings.view_all_text | default: 'View All' }}
      </a>
    </div>
    {% endif %}
  </div>
</section>
