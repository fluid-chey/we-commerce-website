{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}
<!-- Heading section -->
<section class="heading-section {{ section.settings.section_padding_top_mobile | default: 'pt-9xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-9xl' }}  " data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="
  background-color: {{ section.settings.background_color | default: '#000000' }}; 
">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .heading-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
   <div class="container">
     <div class="grid {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} heading-grid">
       <div
         class="heading text-white flex flex-col justify-start lg-tab-justify-end {{ section.settings.heading_spacing_mobile | default: 'space-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:space-lg' }} "
       >
         <h6 class="{{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.tagline_color | default: '#ffffff' }};">{{ section.settings.tagline | default: "Tagline" }}</h6>
         <div class="{{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#ffffff' }};">
           {{ section.settings.heading | default: "Medium length section heading goes here" }}
         </div>
       </div>
       <div class="heading-item flex flex-col {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} text-white">
         <p class="{{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#ffffff' }};">
           {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
         </p>
         <div class="grid {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} sub-heading-grid">
           <div class="flex flex-col {{ section.settings.sub_heading_gap | default: 'space-md' }} ">
             <div class="{{ section.settings.subheading_font_size | default: 'text-xl' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subheading_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.subheading_color | default: '#ffffff' }};">{{ section.settings.subheading_one_title | default: "Subheading one" }}</div>
             <p class="{{ section.settings.subheading_description_font_size | default: 'text-base' }} {{ section.settings.subheading_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subheading_description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.subheading_description_color | default: '#ffffff' }};">
               {{ section.settings.subheading_one_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros." }}
             </p>
           </div>
           <div class="flex flex-col {{ section.settings.sub_heading_gap | default: 'space-md' }} ">
             <div class="{{ section.settings.subheading_font_size | default: 'text-xl' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subheading_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.subheading_color | default: '#ffffff' }};">{{ section.settings.subheading_two_title | default: "Subheading two" }}</div>
             <p class="{{ section.settings.subheading_description_font_size | default: 'text-base' }} {{ section.settings.subheading_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subheading_description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.subheading_description_color | default: '#ffffff' }};">
               {{ section.settings.subheading_two_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros." }}
             </p>
           </div>
         </div>
         <div class="flex justify-start align-center {{ section.settings.sub_heading_gap | default: 'space-md' }} ">
           {% if section.settings.show_button_one %}
          <a href="{{ section.settings.button_one_url | default: '#' }}" class="btn {{ section.settings.button_one_style | default: 'btn-bg-white' }}" style="border-radius: {{ section.settings.button_one_border_radius | default: '' }};">
          {{ section.settings.button_one_text | default: "button 1" }}</a>
           {% endif %}
           {% if section.settings.show_button_two %}
           <a href="{{ section.settings.button_two_url | default: '#' }}" class="btn {{ section.settings.button_two_style | default: 'btn-border-white' }}" style="border-radius: {{ section.settings.button_two_border_radius | default: '' }}">{{ section.settings.button_two_text | default: "button 2" }}</a>
           {% endif %}
         </div>
       </div>
     </div>
   </div>
 </section>

