{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != blank %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Cta section -->
<section class="cta-section {{ section.settings.section_padding_top_mobile | default: 'pt-9xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-9xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#444444' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .cta-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
    .cta-heading {
      color: {{ section.settings.heading_color | default: '#ffffff' }} !important;
    }
    .cta-description {
      color: {{ section.settings.description_color | default: '#ffffff' }} !important;
    }
    .cta-terms {
      color: {{ section.settings.terms_color | default: '#ffffff' }} !important;
    }
    .cta-terms a {
      color: {{ section.settings.terms_link_color | default: '#ffffff' }} !important;
    }
    .cta-terms a:hover {
      color: {{ section.settings.terms_link_color | default: '#ffffff' }} !important;
      opacity: 0.8;
    }
  </style>
  <div class="container">
    <div class="grid grid-cols-1 md-tab-grid-cols-2 {{ section.settings.content_gap_mobile | default: 'space-5xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-7xl' }}">
      <h2 class="cta-heading {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}">
        {{ section.settings.heading | default: "Medium length heading goes here" }}
      </h2>
      <div class="cta-content  ">
        <p class="cta-description {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}">
          {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
        </p>
        {% if section.settings.show_form %}
        <form class="cta-signup flex-col xl-phone-flex-row flex {{ section.settings.content_spacing_mobile | default: 'mt-md' }} {{ section.settings.content_spacing_desktop | default: 'lg:mt-2xl' }} {{ section.settings.form_gap_mobile | default: 'space-md' }} {{ section.settings.form_gap_desktop | default: 'lg:space-md' }}" action="{{ section.settings.form_action | default: '#' }}" method="POST">
          <div class="flex-1">
            <input
              type="email"
              name="email"
              placeholder="{{ section.settings.input_placeholder | default: 'Enter your email' }}"
              class="input-border-white"
              required
            />
          </div>
          <button class="btn {{ section.settings.button_style | default: 'btn-bg-white' }} {{ section.settings.button_border_radius | default: '' }} {{ section.settings.button_font_size | default: 'text-base' }} {{ section.settings.button_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.button_font_weight | default: 'font-medium' }}" type="submit">
            {{ section.settings.button_text | default: "sign up" }}
          </button>
        </form>
        {% endif %}
        {% if section.settings.show_terms %}
        <div class="cta-terms mt-md {{ section.settings.terms_font_size | default: 'text-xs' }} {{ section.settings.terms_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.terms_font_weight | default: 'font-normal' }}">
          {{ section.settings.terms_text | default: "By clicking Sign Up you're confirming that you agree with our" }}
          {% if section.settings.terms_link_url != blank %}
          <a href="{{ section.settings.terms_link_url }}" class="underline">{{ section.settings.terms_link_text | default: "Terms and Conditions" }}</a>.
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

