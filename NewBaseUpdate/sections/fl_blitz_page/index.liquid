{%- style -%}
  .fl-blitz-page {
    --accent: #44b574;
  }

  .fl-blitz-page__hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 160px 24px 100px;
  }
  .fl-blitz-page__hero-ghost {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(140px, 18vw, 260px);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: rgba(255, 255, 255, 0.04);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .fl-blitz-page__hero-content {
    position: relative;
    z-index: 2;
    max-width: 860px;
  }
  .fl-blitz-page__eyebrow {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 28px;
  }
  .fl-blitz-page__hero-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 5.5rem);
    letter-spacing: -0.03em;
    line-height: 1.02;
    text-transform: uppercase;
    color: var(--clr-text-primary);
    margin-bottom: 28px;
  }
  .fl-blitz-page__hero-headline .fl-brand-accent {
    color: var(--accent);
  }
  .fl-blitz-page__hero-sub {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: var(--clr-text-body);
    line-height: 1.65;
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .fl-blitz-page__tagline {
    font-family: var(--ff-brand);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--accent);
    margin-bottom: 40px;
  }

  .fl-blitz-page__section {
    padding: clamp(80px, 10vw, 140px) 0;
    position: relative;
    overflow: hidden;
  }
  .fl-blitz-page__section--cream {
    background: #f5f3ef;
    color: #1a1a1a;
  }
  .fl-blitz-page__section--cream .fl-blitz-page__section-headline { color: #0a0a0a; }
  .fl-blitz-page__section--cream .fl-blitz-page__section-body { color: #3a3a3a; font-weight: 400; }
  .fl-blitz-page__section--cream .fl-blitz-page__section-body strong { color: #0a0a0a; }
  .fl-blitz-page__section--cream .fl-blitz-page__section-label { color: var(--accent); }

  .fl-blitz-page__section-inner {
    max-width: var(--fl-content-max, 1280px);
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 64px);
  }
  .fl-blitz-page__section-label {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .fl-blitz-page__section-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 28px;
    max-width: 720px;
  }
  .fl-blitz-page__section-body {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    color: var(--clr-text-body);
    line-height: 1.7;
    max-width: 720px;
  }
  .fl-blitz-page__section-body p { margin-bottom: 20px; }
  .fl-blitz-page__section-body strong { font-weight: 600; color: var(--clr-text-primary); }

  .fl-blitz-page__timeline-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 6vw, 80px);
    align-items: start;
    max-width: var(--fl-content-max, 1280px);
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 64px);
  }
  .fl-blitz-page__timeline {
    display: flex;
    flex-direction: column;
  }
  .fl-blitz-page__day {
    display: flex;
    gap: 24px;
    padding: 28px 0;
    border-top: 1px solid rgba(68, 181, 116, 0.2);
  }
  .fl-blitz-page__day-num {
    font-family: var(--ff-brand);
    font-size: 1.1rem;
    color: var(--accent);
    min-width: 64px;
    flex-shrink: 0;
  }
  .fl-blitz-page__day-label {
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--clr-text-primary);
    margin-bottom: 6px;
  }
  .fl-blitz-page__day-desc {
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--clr-text-body);
    line-height: 1.6;
  }

  .fl-blitz-page__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: rgba(68, 181, 116, 0.1);
    max-width: var(--fl-content-max, 1280px);
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 64px);
  }
  .fl-blitz-page__fact {
    background: var(--clr-bg, #050505);
    padding: 36px 28px;
    text-align: center;
  }
  .fl-blitz-page__fact-value {
    font-family: var(--ff-brand);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--accent);
    margin-bottom: 8px;
  }
  .fl-blitz-page__fact-label {
    font-size: 0.85rem;
    color: var(--clr-text-secondary);
    line-height: 1.4;
  }

  .fl-blitz-page__cta {
    padding: clamp(100px, 14vw, 200px) 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .fl-blitz-page__cta-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto;
  }
  .fl-blitz-page__cta-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin-bottom: 36px;
  }

  @media (max-width: 768px) {
    .fl-blitz-page__timeline-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .fl-blitz-page__facts {
      grid-template-columns: 1fr;
    }
    .fl-blitz-page__hero { min-height: 70vh; padding: 120px 24px 80px; }
  }
{%- endstyle -%}

<div class="fl-blitz-page">

  <section class="fl-blitz-page__hero">
    <img src="{{ 'brush-texture-04.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-8%;right:-12%;width:50%;opacity:0.15;">
    <img src="{{ 'brush-texture-07.png' | asset_url }}" alt="" class="fl-brushstroke" style="bottom:-10%;left:-10%;width:45%;opacity:0.12;">
    <div class="fl-blitz-page__hero-ghost">4 DAYS</div>
    <div class="fl-blitz-page__hero-content">
      <div class="fl-blitz-page__eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="fl-blitz-page__hero-headline">Live in <span class="fl-brand-accent">four days.</span></h1>
      <p class="fl-blitz-page__hero-sub">{{ section.settings.hero_subtext }}</p>
      <div class="fl-blitz-page__tagline">{{ section.settings.tagline }}</div>
      <a href="{{ section.settings.cta_url }}" class="fl-btn-primary">{{ section.settings.cta_text }}</a>
    </div>
  </section>

  <section class="fl-blitz-page__section">
    <div class="fl-blitz-page__section-inner fl-reveal">
      <div class="fl-blitz-page__section-label">The concept</div>
      <h2 class="fl-blitz-page__section-headline">{{ section.settings.what_headline }}</h2>
      <div class="fl-blitz-page__section-body">{{ section.settings.what_body }}</div>
    </div>
  </section>

  <section class="fl-blitz-page__section fl-blitz-page__section--cream">
    <div class="fl-blitz-page__timeline-grid fl-reveal">
      <div>
        <div class="fl-blitz-page__section-label">The schedule</div>
        <h2 class="fl-blitz-page__section-headline">{{ section.settings.schedule_headline }}</h2>
        <div class="fl-blitz-page__section-body">{{ section.settings.schedule_body }}</div>
      </div>
      <div class="fl-blitz-page__timeline">
        {% for block in section.blocks %}
          {% if block.type == 'day' %}
            <div class="fl-blitz-page__day" {{ block.fluid_attributes }}>
              <div class="fl-blitz-page__day-num">{{ block.settings.day_num }}</div>
              <div>
                <div class="fl-blitz-page__day-label">{{ block.settings.day_label }}</div>
                <div class="fl-blitz-page__day-desc">{{ block.settings.day_desc }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="fl-blitz-page__section">
    <div class="fl-blitz-page__section-inner fl-reveal">
      <div class="fl-blitz-page__section-label">Why it works</div>
      <h2 class="fl-blitz-page__section-headline">{{ section.settings.works_headline }}</h2>
      <div class="fl-blitz-page__section-body">{{ section.settings.works_body }}</div>
    </div>
  </section>

  <section class="fl-blitz-page__section fl-blitz-page__section--cream">
    <div class="fl-blitz-page__section-inner fl-reveal">
      <div class="fl-blitz-page__section-label">Preparation</div>
      <h2 class="fl-blitz-page__section-headline">{{ section.settings.bring_headline }}</h2>
      <div class="fl-blitz-page__section-body">{{ section.settings.bring_body }}</div>
    </div>
  </section>

  <section class="fl-blitz-page__section">
    <div class="fl-blitz-page__section-inner fl-reveal">
      <div class="fl-blitz-page__section-label">Investment</div>
      <h2 class="fl-blitz-page__section-headline">{{ section.settings.invest_headline }}</h2>
      <div class="fl-blitz-page__section-body">{{ section.settings.invest_body }}</div>
    </div>
  </section>

  <section class="fl-blitz-page__section fl-blitz-page__section--cream">
    <div class="fl-blitz-page__facts fl-reveal">
      {% for block in section.blocks %}
        {% if block.type == 'fact' %}
          <div class="fl-blitz-page__fact" {{ block.fluid_attributes }}>
            <div class="fl-blitz-page__fact-value">{{ block.settings.value }}</div>
            <div class="fl-blitz-page__fact-label">{{ block.settings.label }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <section class="fl-blitz-page__cta">
    <img src="{{ 'brush-texture-06.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-12%;right:-18%;width:50%;opacity:0.12;">
    <div class="fl-blitz-page__cta-content fl-reveal">
      <h2 class="fl-blitz-page__cta-headline">{{ section.settings.cta_headline }}</h2>
      <a href="{{ section.settings.cta_url }}" class="fl-btn-primary fl-btn-primary--lg">{{ section.settings.cta_text }}</a>
    </div>
  </section>

</div>

{% schema %}
