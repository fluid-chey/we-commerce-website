<!-- Hero section -->
{%- style -%}
  .hero-section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#000000' }};
  }

  @media (min-width: 1280px) {
    .hero-section-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px;
    }
  }
{%- endstyle -%}
{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}
<!-- Heading section -->
<section class="heading-section hero-section {{ section.settings.section_padding_top_mobile | default: 'pt-9xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-9xl' }}  " data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="
  background-color: {{ section.settings.background_color | default: '#000000' }}; 
">
  {% if use_fluid_widget %}
    <fluid-media-widget media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .heading-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
    <div class="container">
        <div class="hero-content flex flex-col justify-{{ section.settings.text_alignment }} {{ section.settings.content_gap_mobile | default: 'space-2xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-3xl' }} ">
          <h1 class="hero-header-{{ section.settings.header_type | default: 'text-h1' }} {{ section.settings.headline_font_size | default: 'text-h2' }}  {{ section.settings.headline_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.headline_color | default: '#ffffff' }};">{{ section.settings.headline | default: "Medium length hero headline goes here" }}</h1>
          <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#ffffff' }};">
              {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
          </p>
          <div class="flex justify-{{ section.settings.text_alignment }} align-center {{ section.settings.button_gap | default: 'space-lg' }} ">
              {% if section.settings.show_button_one %}
              <a href="{{ section.settings.button_one_url | default: '#' }}" class="btn {{ section.settings.button_one_background_color | default: 'btn-bg-white' }}  {{ section.settings.button_one_border_radius | default: '' }}">{{ section.settings.button_one_text | default: "Button 1" }}</a>
              {% endif %}
              {% if section.settings.show_button_two %}
              <a href="{{ section.settings.button_two_url | default: '#' }}" class="btn {{ section.settings.button_two_background_color | default: 'btn-bg-transparent' }}  {{ section.settings.button_two_border_radius | default: '' }}">{{ section.settings.button_two_text | default: "Button 2" }}</a>
              {% endif %}
          </div>
        </div>
    </div>
</section>

{% schema %}
