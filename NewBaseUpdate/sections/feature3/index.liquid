{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="feature3-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if section.settings.background_image != blank %}
    <div class="feature3-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature3-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 space-7xl align-center {% if section.settings.image_on_left %}feature3-flipped{% endif %}">
      
      <!-- Content Column -->
      <div class="feature3-content">
        <!-- Feature Points Grid (2x2) -->
        <div class="feature3-points grid grid-cols-1 sm-desktop-grid-cols-2 space-4xl mb-4xl">
          
          <!-- Feature Point 1 -->
          <div class="feature3-point">
            <div class="feature3-icon mb-lg">
              {% assign img_input = section.settings.point_1_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != '' %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if img_input != blank %}
                  
                    <img src="{{ img_input}}" alt="{{ block.settings.point_1_image_alt | default: section.settings.point_1_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  <div class="feature3-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_1_heading | default: 'Short heading here' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_1_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>

          <!-- Feature Point 2 -->
          <div class="feature3-point">
            <div class="feature3-icon mb-lg">
              {% assign point_2_image = section.settings.point_2_image %}
              {% assign point_2_fluid_media_id = '' %}
              
              {% if point_2_image.fluid_media_id %}
                {% assign point_2_fluid_media_id = point_2_image.fluid_media_id %}
                {% assign point_2_embed_type = point_2_image.embed_type %}
              {% endif %}

              {% assign use_point_2_fluid_image_widget = false %}
              
              {% if point_2_fluid_media_id != '' %}
                {% assign use_point_2_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_2_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_2_fluid_media_id }}" responsive="true" embed-type="{{ point_2_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_2_image != blank %}
                  
                    <img src="{{ point_2_image }}" alt="{{ block.settings.point_2_image_alt | default: section.settings.point_2_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature3-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                  
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_2_heading | default: 'Short heading here' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_2_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>

          <!-- Feature Point 3 -->
          <div class="feature3-point">
            <div class="feature3-icon mb-lg">
              {% assign point_3_image = section.settings.point_3_image %}
              {% assign point_3_fluid_media_id = '' %}
              
              {% if point_3_image.fluid_media_id %}
                {% assign point_3_fluid_media_id = point_3_image.fluid_media_id %}
                {% assign point_3_embed_type = point_3_image.embed_type %}
              {% endif %}

              {% assign use_point_3_fluid_image_widget = false %}
              
              {% if point_3_fluid_media_id != '' %}
                {% assign use_point_3_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_3_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_3_fluid_media_id }}" responsive="true" embed-type="{{ point_3_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_3_image != blank %}
                  
                    <img src="{{ point_3_image }}" alt="{{ block.settings.point_3_image_alt | default: section.settings.point_3_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature3-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                  
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_3_heading | default: 'Short heading here' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_3_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>

          <!-- Feature Point 4 -->
          <div class="feature3-point">
            <div class="feature3-icon mb-lg">
              {% assign point_4_image = section.settings.point_4_image %}
              {% assign point_4_fluid_media_id = '' %}
              
              {% if point_4_image.fluid_media_id %}
                {% assign point_4_fluid_media_id = point_4_image.fluid_media_id %}
                {% assign point_4_embed_type = point_4_image.embed_type %}
              {% endif %}

              {% assign use_point_4_fluid_image_widget = false %}
              
              {% if point_4_fluid_media_id != '' %}
                {% assign use_point_4_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_4_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_4_fluid_media_id }}" responsive="true" embed-type="{{ point_4_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_4_image != blank %}
                  
                    <img src="{{ point_4_image }}" alt="{{ block.settings.point_4_image_alt | default: section.settings.point_4_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature3-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                  
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_4_heading | default: 'Short heading here' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_4_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>
        </div>

        <!-- Buttons -->
        <div class="feature3-buttons flex flex-wrap space-lg">
          {% if section.settings.show_primary_button and section.settings.primary_button_text != blank %}
            <a href="{{ section.settings.primary_button_link | default: '#' }}" 
               class="btn {{ section.settings.button_style | default: 'btn-bg-primary' }} {{ section.settings.button_border_radius | default: '' }}">
              {{ section.settings.primary_button_text }}
            </a>
          {% endif %}
          
          {% if section.settings.show_secondary_button and section.settings.secondary_button_text != blank %}
            <a href="{{ section.settings.secondary_button_link | default: '#' }}" 
               class="btn {{ section.settings.button_secondary_style | default: 'btn-border-black' }} {{ section.settings.button_secondary_border_radius | default: '' }}">
              {{ section.settings.secondary_button_text }}
              {% if section.settings.secondary_button_arrow %}
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="margin-left: 8px;">
                  <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
                </svg>
              {% endif %}
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Image Column -->
      <div class="feature3-image-wrapper">
        {% assign feature_image_input = section.settings.feature_image %}
          {% assign feature_image_input_fluid_media_id = '' %}
          
          {% if feature_image_input.fluid_media_id %}
            {% assign feature_image_input_fluid_media_id = feature_image_input.fluid_media_id %}
            {% assign feature_image_input_embed_type = feature_image_input.embed_type %}
          {% endif %}

          {% assign use_feature_image_fluid_image_widget = false %}
          
          {% if feature_image_input_fluid_media_id != '' %}
            {% assign use_feature_image_fluid_image_widget = true %}
          {% endif %}

          {% if use_feature_image_fluid_image_widget %}
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          {% else %}
            {% if feature_image_input != blank %}
              
                <img src="{{ feature_image_input }}" alt="{{ block.settings.image_alt | default: section.settings.heading }}" class="feature2-image image-cover" loading="lazy" width="" height=""/>
              
            {% else %}
              
              <div class="feature3-image-placeholder">
                <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-sm mt-md" style=" color: #9ca3af;">Upload feature image</p>
              </div>
              
            {% endif %}
          {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.feature3-section .feature3-wrapper {
  min-height: 400px;
}

.feature3-section .feature3-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Flipped layout - image on left, content on right */
.feature3-section .feature3-flipped .feature3-content {
  order: 2;
}

.feature3-section .feature3-flipped .feature3-image-wrapper {
  order: 1;
}

.feature3-section .feature3-image-wrapper {
  position: relative;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature3-section .feature3-image {
  width: 100%;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature3-section .feature3-image-placeholder {
  width: 100%;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature3-section .feature3-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature3-section .feature3-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 959px) {
  .feature3-section .feature3-wrapper {
    min-height: auto;
    gap: 32px;
  }
  
  .feature3-section .feature3-image,
  .feature3-section .feature3-image-placeholder {
    height: 300px;
  }

  .feature3-section .feature3-points {
    gap: 24px;
    margin-bottom: 32px;
  }

  /* Reset order on mobile - always show content first, then image */
  .feature3-section .feature3-flipped .feature3-content,
  .feature3-section .feature3-flipped .feature3-image-wrapper {
    order: initial;
  }
}

@media (max-width: 767px) {
  .feature3-section .feature3-wrapper {
    gap: 24px;
  }
  
  .feature3-section .feature3-image,
  .feature3-section .feature3-image-placeholder {
    height: 250px;
  }

  .feature3-section .feature3-points {
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .feature3-section .feature3-buttons {
    justify-content: center;
  }
}
</style>

