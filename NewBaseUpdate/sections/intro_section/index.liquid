<!-- Intro section -->
{%- style -%}
  .intro-section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
  }

  @media (min-width: 1280px) {
    .intro-section-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px;
    }
  }
{%- endstyle -%}

<section class="intro-section intro-section-{{ section.id }} {{ section.settings.section_padding_top_mobile | default: 'pt-5xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-5xl' }} ">
    <div class="container">
        <div class="flex flex-col justify-center align-center {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} ">
            
            <div class="{{ section.settings.heading_font_size | default: 'text-h1' }}  {{ section.settings.heading_font_weight | default: 'font-bold' }} leading-1" style="color: {{ section.settings.heading_color | default: '#000000' }};">{{ section.settings.heading | default: "Project name here" }}</div>
            <div class="flex flex-col justify-center align-center {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} ">
                {% if section.settings.paragraph_1 != blank %}
                <p class="{{ section.settings.paragraph_font_size | default: 'text-base' }} {{ section.settings.paragraph_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.paragraph_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.paragraph_color | default: '#000000' }};">
                    {{ section.settings.paragraph_1 }}
                </p>
                {% endif %}
                {% if section.settings.paragraph_2 != blank %}
                <p class="{{ section.settings.paragraph_font_size | default: 'text-base' }} {{ section.settings.paragraph_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.paragraph_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.paragraph_color | default: '#000000' }};">
                    {{ section.settings.paragraph_2 }}
                </p>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Intro Section",
  "tag": "section",
  "class": "intro-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Project name here"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "First Paragraph",
      "default": "Lorem ipsum dolor sit amet. Est optio omnis ex quas voluptas ea corporis fugit id nobis quia. Qui ducimus nesciunt et earum enim in accusamus officia? Ut dolores nesciunt qui distinctio qua qui officiis voluptatem."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Second Paragraph",
      "default": "Lorem ipsum dolor sit amet. Est optio omnis ex quas voluptas ea corporis fugit id nobis quia. Qui ducimus nesciunt et earum enim in accusamus officia? Ut dolores nesciunt qui distinctio qua qui officiis voluptatem."
    },
    {
      "type": "header",
      "content": "Typography"
    },
  
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "options": [
        { "value": "text-h6", "label": "H6" },
        { "value": "text-h5", "label": "H5" },
        { "value": "text-h4", "label": "H4" },
        { "value": "text-h3", "label": "H3" },
        { "value": "text-h2", "label": "H2" },
        { "value": "text-h1", "label": "H1" }
      ],
      "default": "text-h1"
    },
    
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" },
        { "value": "font-extrabold", "label": "Extra Bold" }
      ],
      "default": "font-bold"
    },
    {
      "type": "color_background",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "paragraph_font_size",
      "label": "Paragraph Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "XS" },
        { "value": "text-sm", "label": "SM" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "LG" },
        { "value": "text-xl", "label": "XL" },
        { "value": "text-2xl", "label": "2XL" },
        { "value": "text-3xl", "label": "3XL" },
        { "value": "text-4xl", "label": "4XL" },
        { "value": "text-5xl", "label": "5XL" }
      ],
      "default": "text-base"
    },
    {
      "type": "select",
      "id": "paragraph_font_size_desktop",
      "label": "Paragraph Font Size (Desktop)",
      "options": [
        { "value": "lg:text-xs", "label": "XS" },
        { "value": "lg:text-sm", "label": "SM" },
        { "value": "lg:text-base", "label": "Base" },
        { "value": "lg:text-lg", "label": "LG" },
        { "value": "lg:text-xl", "label": "XL" },
        { "value": "lg:text-2xl", "label": "2XL" },
        { "value": "lg:text-3xl", "label": "3XL" },
        { "value": "lg:text-4xl", "label": "4XL" },
        { "value": "lg:text-5xl", "label": "5XL" }
      ],
      "default": "lg:text-xl"
    },
    {
      "type": "select",
      "id": "paragraph_font_weight",
      "label": "Paragraph Font Weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" }
      ],
      "default": "font-normal"
    },
    {
      "type": "color_background",
      "id": "paragraph_color",
      "label": "Paragraph Color",
      "default": "#000000"
    },
    {
      "type": "header",
