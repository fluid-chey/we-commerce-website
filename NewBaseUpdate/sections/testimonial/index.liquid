{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Testimonial section -->
<section class="testimonial-section {{ section.settings.section_padding_top_mobile | default: 'pt-7xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-7xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .testimonial-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  <div class="container">
    <div class="flex flex-col justify-center align-center {{ section.settings.title_spacing_mobile | default: 'space-xl' }} {{ section.settings.title_spacing_desktop | default: 'lg:space-2xl' }} section-title">
      <div class="{{ section.settings.title_font_size | default: 'text-h2' }} {{ section.settings.title_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.title_color | default: '#000000' }};">
        {{ section.settings.section_title | default: "Customer testimonials" }}
      </div>
      <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#666666' }};">
        {{ section.settings.section_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }}
      </p>
    </div>
    <div class="grid grid-cols-3 {{ section.settings.content_gap_mobile | default: 'space-4xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-5xl' }} testimonial-grid">
      {% for block in section.blocks %}
        <div class="testimonial-col flex flex-col justify-center align-center {{ section.settings.testimonial_spacing_mobile | default: 'space-lg' }} {{ section.settings.testimonial_spacing_desktop | default: 'lg:space-2xl' }} text-center" {{ block.fluid_attributes }}>
          <div class="company-logo">
            <img 
              src="{% if block.settings.company_logo %}{{ block.settings.company_logo | image_url }}{% else %}{{ 'https://ik.imagekit.io/fluid/filestack-migration/filestack_25BaNkw7SYu5hydjLRnk_2REwUeoVr' | asset_url }}{% endif %}" 
              alt="{{ block.settings.company_name | default: 'logo' }}" 
              height=""
              width=""
              loading="lazy"
            />
          </div>
          <p class="{{ block.settings.testimonial_font_size | default: 'text-sm' }} {{ block.settings.testimonial_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.testimonial_font_weight | default: 'font-semibold' }} testimonial-text" style="color: {{ block.settings.testimonial_color | default: '#333333' }};">
            "{{ block.settings.testimonial_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare.' }}"
          </p>
          <div class="author text-center flex justify-center align-center flex-col {{ section.settings.author_spacing_mobile | default: 'space-xs' }} {{ section.settings.author_spacing_desktop | default: 'lg:space-sm' }}">
            <figure class="{{ block.settings.author_image_margin_bottom | default: 'mb-lg' }}">

              {% assign img_input = block.settings.author_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != '' %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if block.settings.author_image != '' %}
                  <img src="{{ block.settings.author_image | image_url }}" alt="{{ block.settings.author_name | default: 'Author' }}" class="image-cover" loading="lazy" width="" height=""/>
                {% else %}
                  <img src="{{ 'avatar.png' | asset_url }}" alt="author" class="image-cover" loading="lazy" width="" height=""/>
                {% endif %}
              {% endif %}
              
            </figure>
            <div class="{{ block.settings.author_name_font_size | default: 'text-sm' }} {{ block.settings.author_name_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.author_name_font_weight | default: 'font-semibold' }} author-name" style="color: {{ block.settings.author_name_color | default: '#000000' }};">
              {{ block.settings.author_name | default: "Name Surname" }}
            </div>
            <p class="{{ block.settings.author_position_font_size | default: 'text-xs' }} {{ block.settings.author_position_font_size_desktop | default: 'lg:text-sm' }} {{ block.settings.author_position_font_weight | default: 'font-normal' }} author-position" style="color: {{ block.settings.author_position_color | default: '#666666' }};">
              {{ block.settings.author_position | default: "Position" }}{% if block.settings.company_name %}, {{ block.settings.company_name }}{% else %}, Company name{% endif %}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

