{%- style -%}
  @media (min-width: 1280px) {
    .shop-product-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 100 }}px !important;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 100 }}px !important;
    }
  }
  
  {% if section.settings.tagline_color != blank %}
  .shop-product-{{ section.id }} .section-tagline {
    color: {{ section.settings.tagline_color }};
  }
  {% endif %}
  
  {% if section.settings.heading_color != blank %}
  .shop-product-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color }};
  }
  {% endif %}
  
  {% if section.settings.description_color != blank %}
  .shop-product-{{ section.id }} .section-description {
    color: {{ section.settings.description_color }};
  }
  {% endif %}
  
  {% if section.settings.product_title_color != blank %}
  .shop-product-{{ section.id }} .product-title {
    color: {{ section.settings.product_title_color }};
  }
  {% endif %}
  
  {% if section.settings.product_variant_color != blank %}
  .shop-product-{{ section.id }} .product-variant {
    color: {{ section.settings.product_variant_color }};
  }
  {% endif %}
  
  {% if section.settings.product_price_color != blank %}
  .shop-product-{{ section.id }} .product-price {
    color: {{ section.settings.product_price_color }};
  }
  {% endif %}
{%- endstyle -%}

<section class="product-collection-section shop-product-{{ section.id }} {{ section.settings.section_padding_top_mobile | default: 'pt-7xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-7xl' }}"  style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  <div class="container">
    <div class="header-section">
      <div class="wrapper lg:flex flex-wrap align-end">
        <div class="desc">
          {% if section.settings.show_tagline %}
            <h6 class="section-tagline {{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }}">
              {% if section.settings.tagline contains 'shop_page.' or section.settings.tagline contains 'shared.' %}
                {{ section.settings.tagline | t }}
              {% else %}
                {{ section.settings.tagline }}
              {% endif %}
            </h6>
          {% endif %}
          
          <div class="section-heading {{ section.settings.heading_spacing_mobile | default: 'py-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:py-lg' }} {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_size_desktop | default: 'text-h1' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}">
            {% if section.settings.heading contains 'shop_page.' or section.settings.heading contains 'shared.' %}
              {{ section.settings.heading | t }}
            {% else %}
              {{ section.settings.heading }}
            {% endif %}
          </div>
          
          {% if section.settings.show_description %}
            <p class="section-description {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}">
              {% if section.settings.description contains 'shop_page.' or section.settings.description contains 'shared.' %}
                {{ section.settings.description | t }}
              {% else %}
                {{ section.settings.description }}
              {% endif %}
            </p>
          {% endif %}
        </div>
        
        {% if section.settings.show_view_all_button %}
          <div class="btn-section text-right hidden lg:block">
            <a href="{{ section.settings.view_all_button_url | default: '#' }}" class="btn {{ section.settings.button_style | default: 'btn-border-black' }} {{ section.settings.button_border_radius | default: '' }}">
              {% if section.settings.view_all_button_text contains 'shop_page.' or section.settings.view_all_button_text contains 'shared.' %}
                {{ section.settings.view_all_button_text | t }}
              {% else %}
                {{ section.settings.view_all_button_text }}
              {% endif %}
            </a>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="product-list-section {{ section.settings.product_list_spacing_mobile | default: 'mt-3xl' }} {{ section.settings.product_list_spacing_desktop | default: 'lg:mt-5xl' }}">
      <ul class="grid grid-cols-1 xl-phone-grid-cols-2 lg-tab-grid-cols-3 {{ section.settings.grid_gap_x_mobile | default: 'space-x-4xl' }} {{ section.settings.grid_gap_x_desktop | default: 'lg:space-x-7xl' }} {{ section.settings.grid_gap_y_mobile | default: 'space-y-7xl' }} {{ section.settings.grid_gap_y_desktop | default: 'lg:space-y-9xl' }}">
        {% for product in collection.products limit: section.settings.products_limit %}
          <li>
            <a href="{{ product.url }}" class="product">
              <div class="image-section product-image-height">
                <img
                  src="{{ product.featured_media.url }}"
                  alt="{{ product.title }}"
                  class="image-cover"
                  width=""
                  height=""
                />
              </div>
              <div class="desc {{ section.settings.product_content_spacing_mobile | default: 'pt-lg' }} {{ section.settings.product_content_spacing_desktop | default: 'lg:pt-lg' }}">
                <div class="product-title {{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_title_font_weight | default: 'font-semibold' }}">
                  {{ product.title }}
                </div>
                {% if section.settings.show_product_variant %}
                  <p class="product-variant {{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.product_variant_font_weight | default: 'font-normal' }} pt-sm">
                    {{ product.selected_or_first_available_variant.title }}
                  </p>
                {% endif %}
                {% unless product.price == 0 or section.settings.hide_price %}
                  <div class="product-price {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} pt-md">
                    {{ product.price }}
                  </div>
                {% endunless %}
              </div>
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

