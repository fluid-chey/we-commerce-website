{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}
<!-- Customer Testimonials -->
<section class="testimonial-section {{ section.settings.section_padding_top_mobile | default: 'pt-5xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-5xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .testimonial-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  <div class="container">
    <div class="header text-center flex flex-col {{ section.settings.title_spacing_mobile | default: 'space-md' }} {{ section.settings.title_spacing_desktop | default: 'lg:space-lg' }}">
      <div class="{{ section.settings.heading_font_size | default: 'text-h1' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">
        {{ section.settings.heading | default: "Customer Testimonials" }}
      </div>
      {% if section.settings.intro_text != blank %}
      <p class="{{ section.settings.intro_font_size | default: 'text-base' }} {{ section.settings.intro_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.intro_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.intro_color | default: '#000000' }};">
        {{ section.settings.intro_text }}
      </p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
    <div class="carousel-section {{ section.settings.content_spacing_mobile | default: 'pt-5xl' }} {{ section.settings.content_spacing_desktop | default: 'lg:pt-5xl' }}">
      <div class="testimonial-carousel splide" id="testimonial-slider-{{ section.id }}">
        <div class="splide__track">
          <ul class="splide__list">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'testimonial' %}
                  <li class="splide__slide" {{ block.fluid_attributes }}>
                    <div class="testimonial-post {{ block.settings.card_padding_x_mobile | default: 'px-2xl' }} {{ block.settings.card_padding_x_desktop | default: 'lg:px-4xl' }} {{ block.settings.card_padding_y_mobile | default: 'py-2xl' }} {{ block.settings.card_padding_y_desktop | default: 'lg:py-4xl' }} border border-solid flex flex-col {{ section.settings.card_spacing_mobile | default: 'space-xl' }} {{ section.settings.card_spacing_desktop | default: 'lg:space-4xl' }}" style="
                      background-color: {{ block.settings.card_background_color | default: '#ffffff' }};
                      border-color: {{ block.settings.card_border_color | default: '#000000' }};
                      border-width: {{ block.settings.card_border_width | default: 1 }}px;
                    ">
                      {% if block.settings.show_rating %}
                      <div class="rating {{ section.settings.rating_spacing_mobile | default: 'mb-sm' }} {{ section.settings.rating_spacing_desktop | default: 'lg:mb-md' }}">
                        {% assign rating = block.settings.rating | default: 5 %}
                        {% for i in (1..5) %}
                          {% if i <= rating %}
                            <svg width="20" height="19" viewBox="0 0 20 19" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: inline-block; margin-right: 4px;">
                              <path d="M9.07088 0.612343C9.41462 -0.204115 10.5854 -0.204114 10.9291 0.612346L12.9579 5.43123C13.1029 5.77543 13.4306 6.01061 13.8067 6.0404L19.0727 6.45748C19.9649 6.52814 20.3267 7.62813 19.6469 8.2034L15.6348 11.5987C15.3482 11.8412 15.223 12.2218 15.3106 12.5843L16.5363 17.661C16.744 18.5211 15.7969 19.201 15.033 18.7401L10.5245 16.0196C10.2025 15.8252 9.7975 15.8252 9.47548 16.0196L4.96699 18.7401C4.20311 19.201 3.25596 18.5211 3.46363 17.661L4.68942 12.5843C4.77698 12.2218 4.65182 11.8412 4.36526 11.5987L0.353062 8.2034C-0.326718 7.62813 0.0350679 6.52814 0.927291 6.45748L6.19336 6.0404C6.5695 6.01061 6.89716 5.77543 7.04207 5.43123L9.07088 0.612343Z" fill="{{ block.settings.star_color | default: '#000000' }}"/>
                            </svg>
                          {% else %}
                            <svg width="20" height="19" viewBox="0 0 20 19" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: inline-block; margin-right: 4px;">
                              <path d="M9.07088 0.612343C9.41462 -0.204115 10.5854 -0.204114 10.9291 0.612346L12.9579 5.43123C13.1029 5.77543 13.4306 6.01061 13.8067 6.0404L19.0727 6.45748C19.9649 6.52814 20.3267 7.62813 19.6469 8.2034L15.6348 11.5987C15.3482 11.8412 15.223 12.2218 15.3106 12.5843L16.5363 17.661C16.744 18.5211 15.7969 19.201 15.033 18.7401L10.5245 16.0196C10.2025 15.8252 9.7975 15.8252 9.47548 16.0196L4.96699 18.7401C4.20311 19.201 3.25596 18.5211 3.46363 17.661L4.68942 12.5843C4.77698 12.2218 4.65182 11.8412 4.36526 11.5987L0.353062 8.2034C-0.326718 7.62813 0.0350679 6.52814 0.927291 6.45748L6.19336 6.0404C6.5695 6.01061 6.89716 5.77543 7.04207 5.43123L9.07088 0.612343Z" fill="#e5e5e5"/>
                            </svg>
                          {% endif %}
                        {% endfor %}
                      </div>
                      {% endif %}
                      <p class="{{ block.settings.testimonial_font_size | default: 'text-base' }} {{ block.settings.testimonial_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.testimonial_font_weight | default: 'font-normal' }}" style="color: {{ block.settings.testimonial_color | default: '#000000' }};">
                        "{{ block.settings.testimonial_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.' }}"
                      </p>

                      <div class="review-author-post flex flex-wrap align-center {{ section.settings.author_spacing_mobile | default: 'space-sm' }} {{ section.settings.author_spacing_desktop | default: 'lg:space-md' }}">
                        <div class="desc col-12 {{ section.settings.author_info_padding_mobile | default: 'pl-md' }} {{ section.settings.author_info_padding_desktop | default: 'lg:pl-lg' }} flex flex-col {{ section.settings.author_info_spacing_mobile | default: 'space-xs' }} {{ section.settings.author_info_spacing_desktop | default: 'lg:space-sm' }}">
                          {% if block.settings.author_name != blank %}
                            <p class="{{ block.settings.author_font_size | default: 'text-sm' }} {{ block.settings.author_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.author_font_weight | default: 'font-semibold' }}" style="color: {{ block.settings.author_color | default: '#000000' }};">
                              {{ block.settings.author_name }}
                            </p>
                          {% endif %}
                          {% if block.settings.author_position != blank %}
                            <p class="{{ block.settings.author_position_font_size | default: 'text-base' }} {{ block.settings.author_position_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.author_position_font_weight | default: 'font-normal' }}" style="color: {{ block.settings.author_position_color | default: '#666666' }};">
                              {{ block.settings.author_position }}
                            </p>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  </li>
              {% endcase %}
            {% endfor %}
          </ul>

          <div class="splide__arrows splide-arrow-section">
            <button class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn">
              <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="currentColor"/>
              </svg>
            </button>
            <button class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn">
              <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="currentColor"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div><!-- .carousel-section -->
    {% endif %}
  </div>
</section>

<script>
  function testimonialCarousel() {
    const testimonialCarousel = new Splide('.testimonial-carousel', {
      perPage: 1,
      perMove: 1,
      speed: 500,
      mediaQuery: "min",
      interval: 5000,
      gap: "32px",
      arrows: false,
      breakpoints: {
        576:{
          perPage: 2,
        },
        768: {
          perPage: 3,
          arrows: true,
        },
      }
    });
    testimonialCarousel.mount();
  }
  document.addEventListener("DOMContentLoaded", () => {
    testimonialCarousel();
  });
</script>

