
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<section class="feature6-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  {% if section.settings.background_image != blank %}
    <div class="feature6-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature6-content text-center mx-auto">
      
      <!-- Feature Image -->
      <div class="feature6-image-wrapper mb-2xl flex justify-center">
       
        {% assign feature_image = section.settings.feature_image %}
        {% assign feature_image_fluid_media_id = '' %}
        
        {% if feature_image.fluid_media_id %}
          {% assign feature_image_fluid_media_id = feature_image.fluid_media_id %}
          {% assign feature_image_embed_type = feature_image.embed_type %}
        {% endif %}

        {% assign use_feature_image_fluid_image_widget = false %}
        
        {% if feature_image_fluid_media_id != blank %}
          {% assign use_feature_image_fluid_image_widget = true %}
        {% endif %}

        {% if use_feature_image_fluid_image_widget %}
          <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
        {% else %}
          {% if feature_image != blank %}
            
              <img src="{{ feature_image | image_url }}" 
                alt="{{ block.settings.image_alt | default: section.settings.heading }}" 
                class="feature6-image" loading="lazy" width="" height=""/>
            
          {% else %}
            
            <div class="feature6-image-placeholder">
              <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
              </svg>
              <p class="text-sm" style="margin-top: 12px; color: #9ca3af;">Upload feature image</p>
            </div>
            
          {% endif %}
        {% endif %}
      </div>
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
        <h2 class="feature6__heading {{ section.settings.heading_size }} mb-2xl" 
            style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      
      <!-- Description -->
      {% if section.settings.description != blank %}
        <p class="feature6-description text-lg" 
           style="color: {{ section.settings.description_color | default: '#6b7280' }};">
          {{ section.settings.description }}
        </p>
      {% endif %}
      
      <!-- Buttons -->
      {% if section.settings.show_buttons %}
        <div class="feature6-buttons flex flex-wrap gap-lg justify-center mt-4xl">
          {% if section.settings.show_primary_button and section.settings.primary_button_text != blank %}
            <a href="{{ section.settings.primary_button_link | default: '#' }}" 
               class="btn {{ section.settings.button_style | default: 'btn-bg-primary' }} {{ section.settings.button_border_radius | default: '' }}">
              {{ section.settings.primary_button_text }}
            </a>
          {% endif %}
          
          {% if section.settings.show_secondary_button and section.settings.secondary_button_text != blank %}
            <a href="{{ section.settings.secondary_button_link | default: '#' }}" 
               class="btn {{ section.settings.button_secondary_style | default: 'btn-border-black' }} {{ section.settings.button_secondary_border_radius | default: '' }}">
              {{ section.settings.secondary_button_text }}
              {% if section.settings.secondary_button_arrow %}
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="margin-left: 8px;">
                  <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
                </svg>
              {% endif %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
.feature6-section .feature6-image {
  width: 100%;
  max-width: 300px;
  height: 200px;
  object-fit: cover;
  border-radius: 12px;
}

.feature6-section .feature6-image-placeholder {
  width: 100%;
  max-width: 300px;
  height: 200px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 767px) {
  .feature6-section .feature6-content {
    max-width: 100%;
  }
  
  .feature6-section .feature6-image-wrapper {
    margin-bottom: 32px;
  }
  
  .feature6-section .feature6-image,
  .feature6-section .feature6-image-placeholder {
    height: 160px;
  }
  
  .feature6-section .feature6__heading {
    margin-bottom: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 6",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Long heading is what you see here in this feature section",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "checkbox",
      "id": "show_buttons",
      "default": false,
      "label": "Show Buttons",
      "info": "Add optional buttons below the description"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "default": "Button",
      "label": "Primary Button Text"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "default": "#",
      "label": "Primary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_primary_button",
      "default": true,
      "label": "Show Primary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "default": "Button",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "default": "#",
      "label": "Secondary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_button",
      "default": true,
      "label": "Show Secondary Button"
    },
    {
      "type": "checkbox",
      "id": "secondary_button_arrow",
      "default": true,
      "label": "Show Arrow on Secondary Button"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },

    {
      "type": "color_background",
      "id": "heading_color",
      "default": "#1a1a1a",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
      "id": "description_color",
      "default": "#6b7280",
      "label": "Description Color"
    },
    {
      "type": "color_background",
      "id": "primary_button_bg",
      "default": "#000000",
      "label": "Primary Button Background"
    },
    {
      "type": "color_background",
      "id": "primary_button_text_color",
      "default": "#ffffff",
      "label": "Primary Button Text Color"
    },
    {
      "type": "color_background",
      "id": "secondary_button_text_color",
      "default": "#000000",
      "label": "Secondary Button Text Color"
    },
    {
      "type": "color_background",
      "id": "secondary_button_border_color",
      "default": "#000000",
      "label": "Secondary Button Border Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "header",
      "cotent": "Buttons styles"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "btn-bg-white", "label": "White" },
        { "value": "btn-bg-primary", "label": "Primary" },
        { "value": "btn-border-white", "label": "White Border" },
        { "value": "btn-border-black", "label": "Black Border" },
        { "value": "btn-border-primary", "label": "Primary Border" }
      ],
      "default": "btn-bg-primary"
    },
    {
      "type": "select",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "rounded", "label": "XS" },
        { "value": "rounded-sm", "label": "SM" },
        { "value": "rounded-md", "label": "MD" },
        { "value": "rounded-lg", "label": "LG" },
        { "value": "rounded-xl", "label": "XL" },
        { "value": "rounded-2xl", "label": "2XL" },
        { "value": "rounded-3xl", "label": "3XL" },
        { "value": "rounded-4xl", "label": "4XL" },
        { "value": "rounded-5xl", "label": "5XL" },
        { "value": "rounded-full", "label": "Full" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "button_secondary_style",
      "label": "Secondary Button Style",
      "options": [
        { "value": "btn-bg-white", "label": "White" },
        { "value": "btn-bg-primary", "label": "Primary" },
        { "value": "btn-border-white", "label": "White Border" },
        { "value": "btn-border-black", "label": "Black Border" },
        { "value": "btn-border-primary", "label": "Primary Border" }
      ],
      "default": "btn-border-black"
    },
    {
      "type": "select",
      "id": "button_secondary_border_radius",
      "label": "Secondary Button Border Radius",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "rounded", "label": "XS" },
        { "value": "rounded-sm", "label": "SM" },
        { "value": "rounded-md", "label": "MD" },
        { "value": "rounded-lg", "label": "LG" },
        { "value": "rounded-xl", "label": "XL" },
        { "value": "rounded-2xl", "label": "2XL" },
        { "value": "rounded-3xl", "label": "3XL" },
        { "value": "rounded-4xl", "label": "4XL" },
        { "value": "rounded-5xl", "label": "5XL" },
        { "value": "rounded-full", "label": "Full" }
      ],
      "default": ""
    }
  ]
}
{% endschema %}