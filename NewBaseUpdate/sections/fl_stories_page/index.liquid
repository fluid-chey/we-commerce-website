{%- style -%}
  .fl-stories-page { --accent: #42b1ff; }

  /* ── Hero ── */
  .fl-stories-page__hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 160px 24px 100px;
  }
  .fl-stories-page__hero-ghost {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(120px, 16vw, 240px);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: rgba(255,255,255,0.04);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }
  .fl-stories-page__hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }
  .fl-stories-page__eyebrow {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 28px;
  }
  .fl-stories-page__hero-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: -0.03em;
    line-height: 1.04;
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .fl-stories-page__hero-sub {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: var(--clr-text-body);
    line-height: 1.65;
    max-width: 600px;
    margin: 0 auto 32px;
  }
  .fl-stories-page__tagline {
    font-family: var(--ff-brand);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    color: var(--accent);
    margin-bottom: 40px;
  }

  /* ── Section Base ── */
  .fl-stories-page__section {
    padding: clamp(80px, 10vw, 140px) 0;
    position: relative;
    overflow: hidden;
  }
  .fl-stories-page__section--cream {
    background: #f5f3ef;
    color: #1a1a1a;
  }
  .fl-stories-page__section--cream .fl-stories-page__s-headline { color: #0a0a0a; }
  .fl-stories-page__section--cream .fl-stories-page__s-body { color: #3a3a3a; font-weight: 400; }
  .fl-stories-page__section--cream .fl-stories-page__s-body strong { color: #0a0a0a; }
  .fl-stories-page__section--cream .fl-stories-page__card { background: #fff; border-color: rgba(0,0,0,0.08); }
  .fl-stories-page__section--cream .fl-stories-page__card-title { color: #0a0a0a; }
  .fl-stories-page__section--cream .fl-stories-page__card-body { color: #3a3a3a; }

  .fl-stories-page__s-inner {
    max-width: var(--fl-content-max, 1280px);
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 64px);
  }
  .fl-stories-page__s-label {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .fl-stories-page__s-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 24px;
    max-width: 720px;
  }
  .fl-stories-page__s-body {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    color: var(--clr-text-body);
    line-height: 1.7;
    max-width: 720px;
  }
  .fl-stories-page__s-body p { margin-bottom: 20px; }
  .fl-stories-page__s-body strong { font-weight: 600; color: var(--clr-text-primary); }

  /* ── Story Placeholder Cards ── */
  .fl-stories-page__story-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: rgba(66,177,255,0.1);
  }
  .fl-stories-page__story-card {
    background: var(--clr-bg, #050505);
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 16px;
    border-top: 3px solid var(--accent);
    opacity: 0.55;
  }
  .fl-stories-page__story-tag {
    font-family: var(--ff-body);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .fl-stories-page__story-quote {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--clr-text-body);
    line-height: 1.6;
  }
  .fl-stories-page__story-status {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25);
    margin-top: auto;
  }

  /* ── Topic Cards Grid ── */
  .fl-stories-page__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: rgba(66,177,255,0.1);
  }
  .fl-stories-page__card {
    background: var(--clr-bg, #050505);
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .fl-stories-page__card-title {
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--clr-text-primary);
  }
  .fl-stories-page__card-body {
    font-size: 0.9rem;
    color: var(--clr-text-body);
    line-height: 1.55;
  }

  /* ── CTA ── */
  .fl-stories-page__cta {
    padding: clamp(100px, 14vw, 200px) 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .fl-stories-page__cta-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .fl-stories-page__cta-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin-bottom: 36px;
  }

  @media (max-width: 768px) {
    .fl-stories-page__story-grid { grid-template-columns: 1fr; }
    .fl-stories-page__cards { grid-template-columns: 1fr; }
    .fl-stories-page__hero { min-height: 70vh; padding: 120px 24px 80px; }
  }
{%- endstyle -%}

<div class="fl-stories-page">

  <!-- ═══ HERO ═══ -->
  <section class="fl-stories-page__hero">
    <img src="{{ 'brush-texture-01.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-6%;right:-10%;width:45%;opacity:0.14;">
    <img src="{{ 'brush-texture-06.png' | asset_url }}" alt="" class="fl-brushstroke" style="bottom:-8%;left:-12%;width:40%;opacity:0.10;">
    <div class="fl-stories-page__hero-ghost">STORIES</div>
    <div class="fl-stories-page__hero-content">
      <div class="fl-stories-page__eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="fl-stories-page__hero-headline">Real companies. <span class="fl-brand-accent">Real results.</span></h1>
      <p class="fl-stories-page__hero-sub">{{ section.settings.hero_subtext }}</p>
      <div class="fl-stories-page__tagline">{{ section.settings.tagline }}</div>
    </div>
  </section>

  <!-- ═══ COMING SOON ═══ -->
  <section class="fl-stories-page__section">
    <div class="fl-stories-page__s-inner fl-reveal">
      <div class="fl-stories-page__s-label">Featured</div>
      <h2 class="fl-stories-page__s-headline">{{ section.settings.featured_headline }}</h2>
      <div class="fl-stories-page__s-body">{{ section.settings.featured_body }}</div>
      <div class="fl-stories-page__story-grid">
        <div class="fl-stories-page__story-card">
          <div class="fl-stories-page__story-tag">{{ section.settings.story_1_tag }}</div>
          <div class="fl-stories-page__story-quote">{{ section.settings.story_1_quote }}</div>
          <div class="fl-stories-page__story-status">Coming soon</div>
        </div>
        <div class="fl-stories-page__story-card">
          <div class="fl-stories-page__story-tag">{{ section.settings.story_2_tag }}</div>
          <div class="fl-stories-page__story-quote">{{ section.settings.story_2_quote }}</div>
          <div class="fl-stories-page__story-status">Coming soon</div>
        </div>
        <div class="fl-stories-page__story-card">
          <div class="fl-stories-page__story-tag">{{ section.settings.story_3_tag }}</div>
          <div class="fl-stories-page__story-quote">{{ section.settings.story_3_quote }}</div>
          <div class="fl-stories-page__story-status">Coming soon</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BROWSE BY TOPIC ═══ -->
  <section class="fl-stories-page__section fl-stories-page__section--cream">
    <div class="fl-stories-page__s-inner fl-reveal">
      <div class="fl-stories-page__s-label">Categories</div>
      <h2 class="fl-stories-page__s-headline">{{ section.settings.browse_headline }}</h2>
      <div class="fl-stories-page__cards">
        <div class="fl-stories-page__card">
          <div class="fl-stories-page__card-title">{{ section.settings.topic_1_title }}</div>
          <div class="fl-stories-page__card-body">{{ section.settings.topic_1_body }}</div>
        </div>
        <div class="fl-stories-page__card">
          <div class="fl-stories-page__card-title">{{ section.settings.topic_2_title }}</div>
          <div class="fl-stories-page__card-body">{{ section.settings.topic_2_body }}</div>
        </div>
        <div class="fl-stories-page__card">
          <div class="fl-stories-page__card-title">{{ section.settings.topic_3_title }}</div>
          <div class="fl-stories-page__card-body">{{ section.settings.topic_3_body }}</div>
        </div>
        <div class="fl-stories-page__card">
          <div class="fl-stories-page__card-title">{{ section.settings.topic_4_title }}</div>
          <div class="fl-stories-page__card-body">{{ section.settings.topic_4_body }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="fl-stories-page__cta">
    <img src="{{ 'brush-texture-06.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-12%;right:-16%;width:48%;opacity:0.12;">
    <div class="fl-stories-page__cta-content fl-reveal">
      <h2 class="fl-stories-page__cta-headline">{{ section.settings.cta_headline }}</h2>
      <a href="{{ section.settings.cta_url }}" class="fl-btn-primary fl-btn-primary--lg">{{ section.settings.cta_text }}</a>
    </div>
  </section>

</div>

