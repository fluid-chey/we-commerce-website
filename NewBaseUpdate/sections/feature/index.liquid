{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != blank %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Feature section-->
<div class="feature-wrapper {{ section.settings.section_padding_top_mobile | default: 'pt-5xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-5xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <style>
    @media (min-width: 1280px) {
      .feature-wrapper {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  {% for block in section.blocks %}
    {% assign feature_class = 'feature-section-' | append: forloop.index %}
    <section class="feature-section {{ feature_class }}" {{ block.fluid_attributes }}>
      <div class="container ">
        <div class="grid {{ section.settings.content_gap_mobile | default: 'space-4xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-5xl' }} feature-grid">
          <div class="feature-content flex justify-center h-full flex-col {{ section.settings.content_spacing_mobile | default: 'space-lg' }} {{ section.settings.content_spacing_desktop | default: 'lg:space-2xl' }} flex-1">
            <div class="{{ block.settings.heading_font_size | default: 'text-h2' }} {{ block.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ block.settings.heading_color | default: '#000000' }};">
              {{ block.settings.heading | default: "Medium length hero heading goes here" }}
            </div>
            <p class="{{ block.settings.body_font_size | default: 'text-base' }} {{ block.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.body_font_weight | default: 'font-normal' }}" style="color: {{ block.settings.body_color | default: '#000000' }};">
              {{ block.settings.body_text | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
            </p>
            <div class="flex justify-start align-center {{ section.settings.button_gap | default: 'space-lg' }}">
              {% if block.settings.show_button_1 %}
                <a href="{{ block.settings.button_1_url | default: '#' }}" class="btn {{ block.settings.button_1_style | default: 'btn-bg-primary' }} {{ block.settings.button_1_border_radius | default: '' }}">
                  {{ block.settings.button_1_text | default: "Button 1" }}
                </a>
              {% endif %}
              {% if block.settings.show_button_2 %}
                <a href="{{ block.settings.button_2_url | default: '#' }}" class="btn {{ block.settings.button_2_style | default: 'btn-border-primary' }} {{ block.settings.button_2_border_radius | default: '' }}">
                  {{ block.settings.button_2_text | default: "Button 2" }}
                </a>
              {% endif %}
            </div>
          </div>
          <div class="feature-image-wrapper">
            <div class="feature-image feature-image-right">
              
              {% assign img_input = block.settings.feature_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if block.settings.feature_image.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if block.settings.feature_image != blank %}
                  <img
                    src="{{ block.settings.feature_image | image_url }}"
                    alt="{{ block.settings.image_alt | default: 'feature' }}"
                    class="image-cover"
                    loading="lazy"
                    width=""
                    height=""
                  />
                {% else %}
                  <img src="{{ 'feature-placeholder.png' | asset_url }}" alt="feature" class="image-cover" loading="lazy" width="" height=""/>
                {% endif %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </section>
    {% endfor %}
  </div>

