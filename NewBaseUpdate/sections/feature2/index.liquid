{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="feature2-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if section.settings.background_image != blank %}
    <div class="feature2-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature2-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 gap-7xl align-center {% if section.settings.image_on_left %}feature2-flipped{% endif %}">
      
      <!-- Content Column -->
      <div class="feature2-content">
        <!-- Main Heading and Description -->
        <div class="feature2-header mb-4xl">
          <h2 class="feature2__heading {{ section.settings.heading_size }} mb-2xl" 
              style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
            {{ section.settings.heading }}
          </h2>
          
          {% if section.settings.description != blank %}
            <p class="text-lg mb-4xl" 
               style="color: {{ section.settings.description_color | default: '#6b7280' }};">
              {{ section.settings.description }}
            </p>
          {% endif %}
        </div>

        <!-- Feature Points -->
        <div class="feature2-points grid grid-cols-1 sm-desktop-grid-cols-2 gap-4xl">
          
          <!-- Feature Point 1 -->
          <div class="feature2-point">
            <div class="feature2-icon mb-lg">
              
              {% assign img_input = section.settings.point_1_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if img_input != blank %}
                  
                    <img src="{{ img_input | image_url }}" alt="{{ block.settings.point_1_image_alt | default: section.settings.point_1_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  <div class="feature2-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_1_heading | default: 'Subheading one' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_1_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>

          <!-- Feature Point 2 -->
          <div class="feature2-point">
            <div class="feature2-icon mb-lg">
              
              {% assign point_2_image = section.settings.point_2_image %}
              {% assign point_2_fluid_media_id = '' %}
              
              {% if point_2_image.fluid_media_id %}
                {% assign point_2_fluid_media_id = point_2_image.fluid_media_id %}
                {% assign point_2_embed_type = point_2_image.embed_type %}
              {% endif %}

              {% assign use_point_2_fluid_image_widget = false %}
              
              {% if point_2_fluid_media_id != blank %}
                {% assign use_point_2_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_2_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_2_fluid_media_id }}" responsive="true" embed-type="{{ point_2_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_2_image != blank %}
                  
                    <img src="{{ point_2_image | image_url }}" alt="{{ block.settings.point_2_image_alt | default: section.settings.point_2_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature2-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                  
                {% endif %}
              {% endif %}
            </div>
            <h3 class="text-lg font-semibold mb-md" 
                style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
              {{ section.settings.point_2_heading | default: 'Subheading two' }}
            </h3>
            <p class="text-md" 
               style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
              {{ section.settings.point_2_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.' }}
            </p>
          </div>
        </div>
      </div>

      <!-- Image Column -->
      <div class="feature2-image-wrapper">
        
          {% assign feature_image_input = section.settings.feature_image %}
          {% assign feature_image_input_fluid_media_id = '' %}
          
          {% if feature_image_input.fluid_media_id %}
            {% assign feature_image_input_fluid_media_id = feature_image_input.fluid_media_id %}
            {% assign feature_image_input_embed_type = feature_image_input.embed_type %}
          {% endif %}

          {% assign use_feature_image_fluid_image_widget = false %}
          
          {% if feature_image_input_fluid_media_id != blank %}
            {% assign use_feature_image_fluid_image_widget = true %}
          {% endif %}

          {% if use_feature_image_fluid_image_widget %}
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          {% else %}
            {% if feature_image_input != blank %}
              
                <img src="{{ feature_image_input | image_url }}" alt="{{ block.settings.image_alt | default: section.settings.heading }}" class="feature2-image image-cover" loading="lazy" width="" height=""/>
              
            {% else %}
              
              <div class="feature2-image-placeholder">
                <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-sm mt-md" style=" color: #9ca3af;">Upload feature image</p>
              </div>
              
            {% endif %}
          {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.feature2-section .feature2-wrapper {
  min-height: 400px;
}

.feature2-section .feature2-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Flipped layout - image on left, content on right */
.feature2-section .feature2-flipped .feature2-content {
  order: 2;
}

.feature2-section .feature2-flipped .feature2-image-wrapper {
  order: 1;
}

.feature2-section .feature2-image-wrapper {
  position: relative;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature2-section .feature2-image {
  width: 100%;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature2-section .feature2-image-placeholder {
  width: 100%;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature2-section .feature2-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature2-section .feature2-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 959px) {
  .feature2-section .feature2-wrapper {
    min-height: auto;
    gap: 32px;
  }
  
  .feature2-section .feature2-image,
  .feature2-section .feature2-image-placeholder {
    height: 300px;
  }

  .feature2-section .feature2-points {
    gap: 24px;
  }

  /* Reset order on mobile - always show content first, then image */
  .feature2-section .feature2-flipped .feature2-content,
  .feature2-section .feature2-flipped .feature2-image-wrapper {
    order: initial;
  }
}

@media (max-width: 767px) {
  .feature2-section .feature2-wrapper {
    gap: 24px;
  }
  
  .feature2-section .feature2-image,
  .feature2-section .feature2-image-placeholder {
    height: 250px;
  }

  .feature2-section .feature2-points {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Long heading is what you see here in this feature section",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        }
      ],
      "default": "h2",
      "label": "Heading Size"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "checkbox",
      "id": "image_on_left",
      "default": false,
      "label": "Image on Left",
      "info": "Check to place image on left side and content on right"
    },
    {
      "type": "image_picker",
      "id": "point_1_image",
      "label": "Feature Point 1 - Image"
    },
    {
      "type": "text",
      "id": "point_1_image_alt",
      "label": "Feature Point 1 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "text",
      "id": "point_1_heading",
      "default": "Subheading one",
      "label": "Feature Point 1 - Heading"
    },
    {
      "type": "textarea",
      "id": "point_1_description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.",
      "label": "Feature Point 1 - Description"
    },
    {
      "type": "image_picker",
      "id": "point_2_image",
      "label": "Feature Point 2 - Image"
    },
    {
      "type": "text",
      "id": "point_2_image_alt",
      "label": "Feature Point 2 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "text",
      "id": "point_2_heading",
      "default": "Subheading two",
      "label": "Feature Point 2 - Heading"
    },
    {
      "type": "textarea",
      "id": "point_2_description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.",
      "label": "Feature Point 2 - Description"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },
    {
      "type": "color_background",
      "id": "heading_color",
      "default": "#1a1a1a",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
      "id": "description_color",
      "default": "#6b7280",
      "label": "Description Color"
    },
    {
      "type": "color_background",
      "id": "point_heading_color",
      "default": "#1a1a1a",
      "label": "Feature Point Heading Color"
    },
    {
      "type": "color_background",
      "id": "point_text_color",
      "default": "#6b7280",
      "label": "Feature Point Text Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ]
}
{% endschema %}