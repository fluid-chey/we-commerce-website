{%- style -%}
  .fl-droplets-page { --seg-droplets: #96C4EC; --accent: var(--seg-droplets); }

  /* ── Hero ── */
  .fl-droplets-page__hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 160px 24px 100px;
  }
  .fl-droplets-page__hero-ghost {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(120px, 16vw, 240px);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: rgba(255,255,255,0.04);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }
  .fl-droplets-page__hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }
  .fl-droplets-page__eyebrow {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 28px;
  }
  .fl-droplets-page__hero-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: -0.03em;
    line-height: 1.04;
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .fl-droplets-page__hero-sub {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: var(--clr-text-body);
    line-height: 1.65;
    max-width: 600px;
    margin: 0 auto 32px;
  }
  .fl-droplets-page__tagline {
    font-family: var(--ff-brand);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    color: var(--accent);
    margin-bottom: 40px;
  }

  /* ── Section Base ── */
  .fl-droplets-page__section {
    padding: clamp(80px, 10vw, 140px) 0;
    position: relative;
    overflow: hidden;
  }
  .fl-droplets-page__section--cream {
    background: #f5f3ef;
    color: #1a1a1a;
  }
  .fl-droplets-page__section--cream .fl-droplets-page__s-headline { color: #0a0a0a; }
  .fl-droplets-page__section--cream .fl-droplets-page__s-body { color: #3a3a3a; font-weight: 400; }
  .fl-droplets-page__section--cream .fl-droplets-page__s-body strong { color: #0a0a0a; }
  .fl-droplets-page__section--cream .fl-droplets-page__card { background: #fff; border-color: rgba(0,0,0,0.08); }
  .fl-droplets-page__section--cream .fl-droplets-page__card-title { color: #0a0a0a; }
  .fl-droplets-page__section--cream .fl-droplets-page__card-body { color: #3a3a3a; }

  .fl-droplets-page__s-inner {
    max-width: var(--fl-content-max, 1280px);
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 64px);
  }
  .fl-droplets-page__s-label {
    font-family: var(--ff-body);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .fl-droplets-page__s-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 24px;
    max-width: 720px;
  }
  .fl-droplets-page__s-body {
    font-family: var(--ff-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    color: var(--clr-text-body);
    line-height: 1.7;
    max-width: 720px;
  }
  .fl-droplets-page__s-body p { margin-bottom: 20px; }
  .fl-droplets-page__s-body strong { font-weight: 600; color: var(--clr-text-primary); }

  /* ── Comparison Cards ── */
  .fl-droplets-page__comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 3vw, 32px);
    margin-top: 40px;
  }
  .fl-droplets-page__compare-card {
    border: 1px solid rgba(150,196,236,0.25);
    border-radius: 12px;
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .fl-droplets-page__compare-card--accent {
    border-color: var(--accent);
  }
  .fl-droplets-page__compare-title {
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--accent);
  }
  .fl-droplets-page__compare-body {
    font-family: var(--ff-body);
    font-size: 0.9rem;
    color: var(--clr-text-body);
    line-height: 1.6;
  }

  /* ── Feature Cards Grid ── */
  .fl-droplets-page__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: rgba(150,196,236,0.1);
  }
  .fl-droplets-page__card {
    background: var(--clr-bg, #050505);
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .fl-droplets-page__card-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--accent);
    opacity: 0.8;
  }
  .fl-droplets-page__card-title {
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--clr-text-primary);
  }
  .fl-droplets-page__card-body {
    font-size: 0.9rem;
    color: var(--clr-text-body);
    line-height: 1.55;
  }
  .fl-droplets-page__card-providers {
    font-family: var(--ff-body);
    font-size: 0.82rem;
    color: var(--accent);
    margin-top: 4px;
    letter-spacing: 0.01em;
  }

  /* ── Callout ── */
  .fl-droplets-page__callout {
    margin-top: 40px;
    border-left: 3px solid var(--accent);
    padding: 24px 28px;
    background: rgba(150,196,236,0.06);
    border-radius: 0 8px 8px 0;
    font-family: var(--ff-body);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    color: var(--clr-text-body);
    line-height: 1.65;
    max-width: 720px;
  }
  .fl-droplets-page__section--cream .fl-droplets-page__callout {
    background: rgba(150,196,236,0.08);
    color: #3a3a3a;
  }

  /* ── CTA ── */
  .fl-droplets-page__cta {
    padding: clamp(100px, 14vw, 200px) 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .fl-droplets-page__cta-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .fl-droplets-page__cta-headline {
    font-family: var(--ff-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin-bottom: 36px;
  }

  @media (max-width: 768px) {
    .fl-droplets-page__comparison,
    .fl-droplets-page__cards { grid-template-columns: 1fr; }
    .fl-droplets-page__hero { min-height: 70vh; padding: 120px 24px 80px; }
  }
{%- endstyle -%}

<div class="fl-droplets-page">

  <!-- ═══ HERO ═══ -->
  <section class="fl-droplets-page__hero">
    <img src="{{ 'brush-texture-02.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-6%;right:-10%;width:45%;opacity:0.14;">
    <img src="{{ 'brush-texture-09.png' | asset_url }}" alt="" class="fl-brushstroke" style="bottom:-8%;left:-12%;width:40%;opacity:0.10;">
    <div class="fl-droplets-page__hero-ghost">DROPLETS</div>
    <div class="fl-droplets-page__hero-content">
      <div class="fl-droplets-page__eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="fl-droplets-page__hero-headline">No platform can anticipate <span class="fl-brand-accent">everything</span> you'll need.</h1>
      <p class="fl-droplets-page__hero-sub">{{ section.settings.hero_subtext }}</p>
      <div class="fl-droplets-page__tagline">{{ section.settings.tagline }}</div>
      <a href="{{ section.settings.cta_url }}" class="fl-btn-primary">{{ section.settings.cta_text }}</a>
    </div>
  </section>

  <!-- ═══ WHAT DROPLETS ARE ═══ -->
  <section class="fl-droplets-page__section">
    <div class="fl-droplets-page__s-inner fl-reveal">
      <div class="fl-droplets-page__s-label">The concept</div>
      <h2 class="fl-droplets-page__s-headline">{{ section.settings.concept_headline }}</h2>
      <div class="fl-droplets-page__s-body">{{ section.settings.concept_body }}</div>
      <div class="fl-droplets-page__comparison">
        <div class="fl-droplets-page__compare-card">
          <div class="fl-droplets-page__compare-title">{{ section.settings.compare_traditional_title }}</div>
          <div class="fl-droplets-page__compare-body">{{ section.settings.compare_traditional_body }}</div>
        </div>
        <div class="fl-droplets-page__compare-card fl-droplets-page__compare-card--accent">
          <div class="fl-droplets-page__compare-title">{{ section.settings.compare_droplet_title }}</div>
          <div class="fl-droplets-page__compare-body">{{ section.settings.compare_droplet_body }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MARKETPLACE ═══ -->
  <section class="fl-droplets-page__section fl-droplets-page__section--cream">
    <div class="fl-droplets-page__s-inner fl-reveal">
      <div class="fl-droplets-page__s-label">Available now</div>
      <h2 class="fl-droplets-page__s-headline">{{ section.settings.marketplace_headline }}</h2>
      <div class="fl-droplets-page__cards">
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.market_card_1_title }}</div>
          <div class="fl-droplets-page__card-providers">{{ section.settings.market_card_1_providers }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.market_card_2_title }}</div>
          <div class="fl-droplets-page__card-providers">{{ section.settings.market_card_2_providers }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.market_card_3_title }}</div>
          <div class="fl-droplets-page__card-providers">{{ section.settings.market_card_3_providers }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.market_card_4_title }}</div>
          <div class="fl-droplets-page__card-providers">{{ section.settings.market_card_4_providers }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT CAN BE BUILT ═══ -->
  <section class="fl-droplets-page__section">
    <div class="fl-droplets-page__s-inner fl-reveal">
      <div class="fl-droplets-page__s-label">Possibilities</div>
      <h2 class="fl-droplets-page__s-headline">{{ section.settings.possibilities_headline }}</h2>
      <div class="fl-droplets-page__cards">
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.poss_card_1_title }}</div>
          <div class="fl-droplets-page__card-body">{{ section.settings.poss_card_1_body }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.poss_card_2_title }}</div>
          <div class="fl-droplets-page__card-body">{{ section.settings.poss_card_2_body }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.poss_card_3_title }}</div>
          <div class="fl-droplets-page__card-body">{{ section.settings.poss_card_3_body }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.poss_card_4_title }}</div>
          <div class="fl-droplets-page__card-body">{{ section.settings.poss_card_4_body }}</div>
        </div>
        <div class="fl-droplets-page__card">
          <div class="fl-droplets-page__card-title">{{ section.settings.poss_card_5_title }}</div>
          <div class="fl-droplets-page__card-body">{{ section.settings.poss_card_5_body }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONNECT RUNS ON DROPLETS ═══ -->
  <section class="fl-droplets-page__section fl-droplets-page__section--cream">
    <div class="fl-droplets-page__s-inner fl-reveal">
      <div class="fl-droplets-page__s-label">Foundation</div>
      <h2 class="fl-droplets-page__s-headline">{{ section.settings.connect_headline }}</h2>
      <div class="fl-droplets-page__s-body">{{ section.settings.connect_body }}</div>
      <div class="fl-droplets-page__callout">{{ section.settings.connect_callout }}</div>
    </div>
  </section>

  <!-- ═══ ECOSYSTEM ═══ -->
  <section class="fl-droplets-page__section">
    <div class="fl-droplets-page__s-inner fl-reveal">
      <div class="fl-droplets-page__s-label">Growth</div>
      <h2 class="fl-droplets-page__s-headline">{{ section.settings.ecosystem_headline }}</h2>
      <div class="fl-droplets-page__s-body">{{ section.settings.ecosystem_body }}</div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="fl-droplets-page__cta">
    <img src="{{ 'brush-texture-09.png' | asset_url }}" alt="" class="fl-brushstroke" style="top:-12%;right:-16%;width:48%;opacity:0.12;">
    <div class="fl-droplets-page__cta-content fl-reveal">
      <h2 class="fl-droplets-page__cta-headline">{{ section.settings.cta_headline }}</h2>
      <a href="{{ section.settings.cta_url }}" class="fl-btn-primary fl-btn-primary--lg">{{ section.settings.cta_bottom_text }}</a>
    </div>
  </section>

</div>

