      "label": "Hero CTA text",
      "default": "See Fluid Connect in action →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA url",
      "default": "/home/pages/contact"
    },
    {
      "type": "header",
      "content": "How It Works"
    },
    {
      "type": "text",
      "id": "how_label",
      "label": "Section label",
      "default": "Integration"
    },
    {
      "type": "text",
      "id": "how_headline",
      "label": "Headline",
      "default": "One-click connection"
    },
    {
      "type": "text",
      "id": "step1_title",
      "label": "Step 1 title",
      "default": "Select commission engine"
    },
    {
      "type": "text",
      "id": "step1_detail",
      "label": "Step 1 detail",
      "default": "Exigo, ByDesign, Pillars"
    },
    {
      "type": "text",
      "id": "step2_title",
      "label": "Step 2 title",
      "default": "Enter credentials"
    },
    {
      "type": "text",
