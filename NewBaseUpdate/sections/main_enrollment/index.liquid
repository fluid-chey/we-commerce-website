{%- style -%}

  {% if section.settings.breadcrumb_color != blank %}
  .enrollment-pack-section-{{ section.id }} .breadcrumb {
    color: {{ section.settings.breadcrumb_color }};
  }
  {% endif %}

  {% if section.settings.breadcrumb_active_color != blank %}
  .enrollment-pack-section-{{ section.id }} .breadcrumb .active {
    color: {{ section.settings.breadcrumb_active_color }};
  }
  {% endif %}

  {% if section.settings.product_title_color != blank %}
  .enrollment-pack-{{ section.id }} .product-title {
    color: {{ section.settings.product_title_color }};
  }
  {% endif %}

  {% if section.settings.product_price_color != blank %}
  .enrollment-pack-{{ section.id }} .product-price {
    color: {{ section.settings.product_price_color }};
  }
  {% endif %}

  {% if section.settings.subscription_product_title_color != blank %}
  .enrollment-pack-{{ section.id }} .subscription-product-title {
    color: {{ section.settings.subscription_product_title_color }};
  }
  {% endif %}

  {% if section.settings.subscription_product_price_color != blank %}
  .enrollment-pack-{{ section.id }} .subscription-product-price {
    color: {{ section.settings.subscription_product_price_color }};
  }
  {% endif %}

  {% if section.settings.subscription_info_text_color != blank %}
  .enrollment-pack-{{ section.id }} .enrollment-pack .desc .info {
    color: {{ section.settings.subscription_info_text_color }};
  }
  {% endif %}

  {% if section.settings.subscription_learn_more_color != blank %}
  .enrollment-pack-{{ section.id }} .enrollment-pack .desc .learn-more-section a {
    color: {{ section.settings.subscription_learn_more_color }};
  }
  {% endif %}

  .enrollment-pack-{{ section.id }} .subscription-product {
    background-color: var(--{{ section.settings.enrollment_pack_background_color  }});
    border-width: {{ section.settings.enrollment_pack_border_width  }}px;
    border-color: var(--{{ section.settings.enrollment_pack_border_color }});
  }
  /* Membership Product */
  .enrollment-pack-{{ section.id }} .membership-product {
    background-color: var(--{{ section.settings.membership_product_background_color }});
    border-width: {{ section.settings.membership_product_border_width }}px;
    border-color: var(--{{ section.settings.membership_product_border_color }});
  }

{%- endstyle -%}
<main class="enrollment-page-section content-min-height enrollment-pack-section-{{ section.id }} {{ section.settings.section_padding_y_mobile | default: 'py-2xl' }} {{ section.settings.section_padding_y_desktop | default: 'py-10xl' }}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if section.settings.show_breadcrumb %}
  <div class="breadcrumb {{ section.settings.breadcrumb_font_size | default: 'text-sm' }}">
      <div class="container">
        <ul class="flex flex-wrap align-center space-sm leading-none">
          <li class="flex space-sm align-center">
            <a href="{{ company.join_page_url }}">{{ 'enrollment_pack.all_products' | t }}</a>
              <span class="seperator">
                  <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M8.56641 7.70703C8.88281 8.05859 8.88281 8.58594 8.56641 8.90234L1.81641 15.6523C1.46484 16.0039 0.9375 16.0039 0.621094 15.6523C0.269531 15.3359 0.269531 14.8086 0.621094 14.4922L6.77344 8.33984L0.621094 2.15234C0.269531 1.83594 0.269531 1.30859 0.621094 0.992188C0.9375 0.640625 1.46484 0.640625 1.78125 0.992188L8.56641 7.70703Z" fill="currentColor"/>
                  </svg>
              </span>
          </li>
          <li>
            <a href="#" class="active font-semibold">{{ enrollment_pack.title }}</a>
          </li>
        </ul>
      </div>
  </div>
  {% endif %}
  <section class="product-details-section enrollment-pack-{{ section.id }} mt-xl">
      <div class="container">
           <div class="grid {{ section.settings.grid_layout | default: 'grid-cols-1 xl-tab-grid-cols-2' }} {{ section.settings.grid_gap_x | default: 'space-x-4xl' }} {{ section.settings.grid_gap_y | default: 'space-y-4xl' }}">
              <div class="slider-section">

                  <div class="splide main-slider-section" id="enrollment-slider">
                      <div class="splide__track">
                          <ul class="splide__list">
                          {%  for image in images_array %}
                              <li class="splide__slide">
                                  <img src="{{ image }}" alt="product" data-zoom-image="{{ image }}">
                              </li>
                          {% endfor %}
                          </ul>
                      </div>
                  </div><!-- .splide slider-section -->

                  <div  class="splide thumbnail-carousel-section mt-2xl" id="enrollment-thumbnail-carousel">
                      <div class="splide__track">
                          <ul class="splide__list splide-list">
                          {%  for image in images_array %}
                              <li class="splide__slide">
                                  <img src="{{ image }}" alt="product">
                              </li>
                          {% endfor %}
                          </ul>
                      </div>
                  </div>
                  <!-- .thumbnail-carousel-section -->
              </div><!-- .image-section -->

              
              <div class="product-details">
                  <div class="flex flex-col space-y-sm">

                    <div class="product-title {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'text-h3' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }}">{{ enrollment_pack.title }}</div>
                    <div class="flex gap-1 align-center">
                      <div class="product-price {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-medium' }}">
                        {{ enrollment_pack.price }}
                      </div>
                      <div class="enrollment-fee text-sm font-medium text-secondary">
                        enrollment fee
                      </div>
                    </div>
                  
                    {% if section.settings.show_rating %}
                      <div class="rating">
                          <svg width="101" height="21" viewBox="0 0 101 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M11.0207 2.88369C10.6997 2.11169 9.60575 2.11169 9.28475 2.88369L7.45475 7.28469L2.70175 7.66569C1.86875 7.73269 1.53075 8.77269 2.16575 9.31669L5.78575 12.4187L4.67975 17.0557C4.48575 17.8687 5.37075 18.5117 6.08475 18.0757L10.1527 15.5907L14.2217 18.0757C14.9347 18.5117 15.8197 17.8687 15.6257 17.0557L14.5197 12.4187L18.1397 9.31669C18.7747 8.77269 18.4367 7.73269 17.6037 7.66669L12.8517 7.28469L11.0207 2.88369Z" fill="#FFAE00"/>
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M31.0207 2.88369C30.6997 2.11169 29.6057 2.11169 29.2847 2.88369L27.4547 7.28469L22.7017 7.66569C21.8687 7.73269 21.5307 8.77269 22.1657 9.31669L25.7857 12.4187L24.6797 17.0557C24.4857 17.8687 25.3707 18.5117 26.0847 18.0757L30.1527 15.5907L34.2217 18.0757C34.9347 18.5117 35.8197 17.8687 35.6257 17.0557L34.5197 12.4187L38.1397 9.31669C38.7747 8.77269 38.4367 7.73269 37.6037 7.66669L32.8517 7.28469L31.0207 2.88369Z" fill="#FFAE00"/>
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M51.0207 2.88369C50.6997 2.11169 49.6057 2.11169 49.2847 2.88369L47.4547 7.28469L42.7017 7.66569C41.8687 7.73269 41.5307 8.77269 42.1657 9.31669L45.7857 12.4187L44.6797 17.0557C44.4857 17.8687 45.3707 18.5117 46.0847 18.0757L50.1527 15.5907L54.2217 18.0757C54.9347 18.5117 55.8197 17.8687 55.6257 17.0557L54.5197 12.4187L58.1397 9.31669C58.7747 8.77269 58.4367 7.73269 57.6037 7.66669L52.8517 7.28469L51.0207 2.88369Z" fill="#FFAE00"/>
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M71.0207 2.88369C70.6997 2.11169 69.6057 2.11169 69.2847 2.88369L67.4547 7.28469L62.7017 7.66569C61.8687 7.73269 61.5307 8.77269 62.1657 9.31669L65.7857 12.4187L64.6797 17.0557C64.4857 17.8687 65.3707 18.5117 66.0847 18.0757L70.1527 15.5907L74.2217 18.0757C74.9347 18.5117 75.8197 17.8687 75.6257 17.0557L74.5197 12.4187L78.1397 9.31669C78.7747 8.77269 78.4367 7.73269 77.6037 7.66669L72.8517 7.28469L71.0207 2.88369Z" fill="#FFAE00"/>
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M91.0207 2.88369C90.6997 2.11169 89.6057 2.11169 89.2847 2.88369L87.4547 7.28469L82.7017 7.66569C81.8687 7.73269 81.5307 8.77269 82.1657 9.31669L85.7857 12.4187L84.6797 17.0557C84.4857 17.8687 85.3707 18.5117 86.0847 18.0757L90.1527 15.5907L94.2217 18.0757C94.9347 18.5117 95.8197 17.8687 95.6257 17.0557L94.5197 12.4187L98.1397 9.31669C98.7747 8.77269 98.4367 7.73269 97.6037 7.66669L92.8517 7.28469L91.0207 2.88369Z" fill="#D0D5DD"/>
                          </svg>
                      </div>
                    {% endif %}
                    <p>{{ description | raw }}</p>
                  </div>

                  <div class="details flex flex-col space-y-2xl pt-2xl">
                      {% for product in membership_products %}
                        <div class="enrollment-pack membership-product md-tab-flex flex-wrap align-center border-0 {{ section.settings.membership_product_border_radius }} {{ section.settings.membership_product_padding }}">
                          <div class="image-section md-tab-order-2">
                            <div class="wrapper">
                              <img src="{{ product.image_url }}" alt="enrollment pack" class="image-cover rounded">
                            </div>
                          </div>
                          <div class="desc md-tab-order-1 mt-2xl md-tab-m-0">
                            <div class="pr-md">
                              {% if section.settings.show_todays_purchase_text %}
                                <p class="text-secondary">{{ section.settings.membership_product_heading }}</p>
                              {% endif %}
                              <div class="product-title subscription-product-title leading-8 {{ section.settings.subscription_product_title_font_size | default: 'text-lg' }} {{ section.settings.subscription_product_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subscription_product_title_font_weight | default: 'font-bold' }}">{{ product.title }}</div>
                              <div class="price  subscription-product-price leading-8 {{ section.settings.subscription_product_price_font_size | default: 'text-lg' }} {{ section.settings.subscription_product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subscription_product_price_font_weight | default: 'font-medium' }}">{{ product.price }}</div>
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                      

                      {% for product in subscription_products %}
                      <div class="enrollment-pack subscription-product border {{ section.settings.enrollment_pack_padding }} {{ section.settings.enrollment_pack_border_radius  }} md-tab-flex flex-wrap align-center">
                          <div class="image-section md-tab-order-2">
                              <div class="wrapper">
                              <img src="{{ product.image }}" alt="enrollment pack" class="image-cover rounded">
                              </div>
                          </div>

                          <div class="desc md-tab-order-1 mt-2xl md-tab-m-0">
                              <div class="pr-md">
                                  <div class="product-title subscription-product-title leading-8 {{ section.settings.subscription_product_title_font_size | default: 'text-lg' }} {{ section.settings.subscription_product_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subscription_product_title_font_weight | default: 'font-bold' }}">{{ product.title }}</div>
                                  <div class="price subscription-product-price leading-8 {{ section.settings.subscription_product_price_font_size | default: 'text-lg' }} {{ section.settings.subscription_product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subscription_product_price_font_weight | default: 'font-medium' }}">{{ product.price }}</div>
                                  <ul class="info text-secondary flex flex-col space-y-xs pt-md {{ section.settings.subscription_info_text_font_size | default: 'text-sm' }}">
                                      <li>{{ 'enrollment_pack.monthly_subscription' | t }}</li>
                                      <li>{{ 'enrollment_pack.first_payment' | t: date: first_payment_date }}</li>
                                  </ul>
                              </div>
                              <!-- TODO: Remove class md-tab-text-right if size is not available-->
                              <div class="learn-more-section pt-4xl md-tab-text-left">
                                  <a href="{{ product.learn_more_path }}" class="{{ section.settings.subscription_learn_more_font_size | default: 'text-base' }}">{{ 'enrollment_pack.learn_more' | t }}</a>
                              </div>
                          </div>
                      </div><!-- .enrollment-pack -->
                      {% endfor %}

                      <div class="btn-section">
                          <div
                              class="w-full"
                              data-fluid-checkout-group
                              data-enrollment-pack='{{ enrollment_pack.id }}'
                          >
                              <button
                                  type="button"
                                  class='btn w-full checkout-button {{ section.settings.button_padding_y | default: 'py-md' }} {{ section.settings.button_padding_x | default: 'px-4xl' }} {{ section.settings.button_border_radius | default: 'rounded-md' }} {{ section.settings.button_font_size | default: 'text-base' }} {{ section.settings.button_font_weight | default: 'font-medium' }}'
                                  style="background-color: {{ section.settings.button_background_color | default: '#000000' }}; color: {{ section.settings.button_text_color | default: '#ffffff' }};"
                                  data-fluid-add-enrollment-pack="{{ enrollment_pack.id }}"
                              >
                                  {{ 'enrollment_pack.checkout' | t }}
                              </button>
                          </div>
                      </div>
                  </div>

              </div><!-- .product-details -->
          </div>
          <!-- .grid -->
      </div><!-- .container -->
  </section>
</main>
<script src="{{ 'enrollment.js' | asset_url }}"></script>

{% schema %}
