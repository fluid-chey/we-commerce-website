{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<section class="banner relative placeholde-bg-color {{ section.settings.section_padding_top_mobile | default: 'pt-7xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-7xl' }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#000000' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  {% comment %} {% if section.settings.background_image %}
    <img src="{{ section.settings.background_image | img_url: 'master' }}" alt="{{ section.settings.background_image.alt | default: 'Banner background' }}" class="absolute top-0 left-0 image-cover">
  {% endif %} {% endcomment %}
  
  {% if section.settings.show_overlay %}
    <div class="overlay-gradient absolute top-0 left-0 w-full h-full z-1" style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; opacity: {{ section.settings.overlay_opacity | default: 0.5 }};"></div>
  {% endif %}
  
  <style>
    @media (min-width: 1280px) {
      .banner {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
    .tagline {
      color: {{ section.settings.tagline_color | default: '#ffffff' }} !important;
    }
    .heading {
      color: {{ section.settings.heading_color | default: '#ffffff' }} !important;
    }
    .description {
      color: {{ section.settings.description_color | default: '#ffffff' }} !important;
    }
    .cta-button {
      background-color: {{ section.settings.button_background_color | default: '#ffffff' }};
      color: {{ section.settings.button_text_color | default: '#000000' }};
      border: {{ section.settings.button_border_width | default: 1 }}px solid {{ section.settings.button_border_color | default: '#ffffff' }};
    }
  </style>
  
  <div class="container relative z-2">
    <div class="wrapper xl-phone-flex flex-col justify-{{ section.settings.text_alignment | default: 'center' }}">
      {% if section.settings.show_tagline %}
        <h6 class="tagline leading-none {{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }}">
          {% if section.settings.tagline contains 'shop_page.' or section.settings.tagline contains 'shared.' %}
            {{ section.settings.tagline | t }}
          {% else %}
            {{ section.settings.tagline }}
          {% endif %}
        </h6>
      {% endif %}
      
      <div class="heading {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_spacing_mobile | default: 'pt-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:pt-lg' }}">
        {% if section.settings.heading contains 'shop_page.' or section.settings.heading contains 'shared.' %}
          {{ section.settings.heading | t }}
        {% else %}
          {{ section.settings.heading }}
        {% endif %}
      </div>
      
      {% if section.settings.show_description %}
        <p class="description {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} leading-6 {{ section.settings.description_spacing_mobile | default: 'pt-lg' }} {{ section.settings.description_spacing_desktop | default: 'lg:pt-xl' }}">
          {% if section.settings.description contains 'shop_page.' or section.settings.description contains 'shared.' %}
            {{ section.settings.description | t }}
          {% else %}
            {{ section.settings.description }}
          {% endif %}
        </p>
      {% endif %}
      
      {% if section.settings.show_button %}
        <div class="{{ section.settings.button_spacing_mobile | default: 'pt-2xl' }} {{ section.settings.button_spacing_desktop | default: 'lg:pt-4xl' }} flex justify-start align-center">
          <a href="{{ section.settings.button_url | default: '#' }}" class="cta-button btn {{ section.settings.button_style | default: 'btn-bg-white' }} {{ section.settings.button_border_radius | default: '' }}">
            {{ section.settings.button_text | default: 'Shop Now' }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

