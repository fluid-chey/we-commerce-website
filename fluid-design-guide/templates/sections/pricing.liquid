<!-- FIXED: Section wrapper with utility class application from schema settings -->
<!-- FIXED: Container wrapper with full 7-setting customization -->
<!-- FLEXIBLE: Heading, subheading text content and all typography settings -->
<!-- FLEXIBLE: Pricing tier blocks with name, price, period, features, CTA button -->
<!-- OPTIONAL: Subheading, highlighted tier (conditionally rendered) -->

<!-- Pricing Section -->
<!-- Gold Standard compliant -- 2 text elements, 1 button, 5 section settings, 7 container settings + pricing_tier blocks -->

<section
  class="section-pricing {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>

  <div class="container {{ section.settings.container_background_color | default: 'bg-transparent' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}"
    {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>


    {% if section.settings.heading != blank %}
    <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-primary' }}">
      {{ section.settings.heading | default: 'Pricing Plans' }}
    </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
    <p class="{{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-lg' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-secondary' }}">
      {{ section.settings.subheading | default: '' }}
    </p>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
      {% for block in section.blocks %}
        {% if block.type == 'pricing_tier' %}
        <div {{ block.fluid_attributes }} class="pricing-card{% if block.settings.highlighted %} highlighted{% endif %}">
          {% if block.settings.name != blank %}
          <h3 class="{{ block.settings.name_font_family | default: 'font-body' }} {{ block.settings.name_font_size | default: 'text-base' }} {{ block.settings.name_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.name_font_weight | default: 'font-normal' }} {{ block.settings.name_color | default: 'text-primary' }}">
            {{ block.settings.name }}
          </h3>
          {% endif %}

          {% if block.settings.price != blank %}
          <div class="{{ block.settings.price_font_family | default: 'font-body' }} {{ block.settings.price_font_size | default: 'text-base' }} {{ block.settings.price_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.price_font_weight | default: 'font-normal' }} {{ block.settings.price_color | default: 'text-primary' }}">
            {{ block.settings.price }}
          </div>
          {% endif %}

          {% if block.settings.period != blank %}
          <div class="{{ block.settings.period_font_family | default: 'font-body' }} {{ block.settings.period_font_size | default: 'text-base' }} {{ block.settings.period_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.period_font_weight | default: 'font-normal' }} {{ block.settings.period_color | default: 'text-primary' }}">
            {{ block.settings.period }}
          </div>
          {% endif %}

          {% if block.settings.features != blank %}
          <div class="features-list {{ block.settings.features_font_family | default: 'font-body' }} {{ block.settings.features_font_size | default: 'text-sm' }} {{ block.settings.features_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.features_font_weight | default: 'font-normal' }} {{ block.settings.features_color | default: 'text-secondary' }}">
            {{ block.settings.features }}
          </div>
          {% endif %}

          {% if block.settings.cta_text != blank %}
          <span class="{{ block.settings.cta_text_font_family | default: 'font-body' }} {{ block.settings.cta_text_font_size | default: 'text-base' }} {{ block.settings.cta_text_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.cta_text_font_weight | default: 'font-normal' }} {{ block.settings.cta_text_color | default: 'text-primary' }}">
            {{ block.settings.cta_text }}
          </span>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_button %}
    <a href="{{ section.settings.button_url | default: '#' }}"
       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} {{ settings.button_border_radius | default: 'rounded' }}">
      {{ section.settings.button_text | default: 'Learn More' }}
    </a>
    {% endif %}

  </div>
</section>

<style>
  {% render 'section-css', section_id: 'pricing' %}
</style>

