<!-- Features Grid Section -->
<!-- Gold Standard compliant — 1 text element, 0 buttons, 5 section settings, 7 container settings + feature_item blocks -->

<section
  class="section-features-grid {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>

  <div class="container {{ section.settings.container_background_color | default: 'bg-transparent' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}"
    {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>

    {% if section.settings.heading != blank %}
    <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-primary' }}">
      {{ section.settings.heading | default: 'Features' }}
    </h2>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
      {% for block in section.blocks %}
        {% if block.type == 'feature_item' %}
        <div {{ block.fluid_attributes }}>
          {% if block.settings.icon_text != blank %}
          <div class="{{ block.settings.icon_text_font_family | default: 'font-primary' }} {{ block.settings.icon_text_font_size | default: 'text-2xl' }} {{ block.settings.icon_text_font_size_desktop | default: 'lg:text-3xl' }} {{ block.settings.icon_text_font_weight | default: 'font-bold' }} {{ block.settings.icon_text_color | default: 'text-accent' }}">
            {{ block.settings.icon_text }}
          </div>
          {% endif %}

          {% if block.settings.title != blank %}
          <h3 class="{{ block.settings.title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: 'font-semibold' }} {{ block.settings.title_color | default: 'text-primary' }}">
            {{ block.settings.title }}
          </h3>
          {% endif %}

          {% if block.settings.description != blank %}
          <p class="{{ block.settings.description_font_family | default: 'font-body' }} {{ block.settings.description_font_size | default: 'text-base' }} {{ block.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-secondary' }}">
            {{ block.settings.description }}
          </p>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_button %}
    <a href="{{ section.settings.button_url | default: '#' }}"
       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} {{ settings.button_border_radius | default: 'rounded' }}">
      {{ section.settings.button_text | default: 'Learn More' }}
    </a>
    {% endif %}

  </div>
</section>

<style>
  {% render 'section-css', section_id: 'features-grid' %}
</style>

